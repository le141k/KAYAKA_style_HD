  },
  "motion": { "enter": "200ms ease-out", "exit": "150ms ease-in", "respectReducedMotion": true },
  "accentCycle": ["brand", "cyan", "indigo"],
  "status": {
    "open": "#1A7FE0", "pending": "#F59E0B", "progress": "#6366F1",
    "resolved": "#16A34A", "closed": "#64748B",
    "slaOk": "#16A34A", "slaWarn": "#F59E0B", "slaBreach": "#DC2626",
    "priorityUrgent": "#DC2626", "priorityHigh": "#F97316",
    "priorityNormal": "#1A7FE0", "priorityLow": "#64748B"
  }
