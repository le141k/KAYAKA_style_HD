{
  "name": "Telecom Signal",
  "source": "docs/brand/brand-guidelines.md",
  "typography": {
    "ui": "Inter, -apple-system, \"Segoe UI\", Arial, sans-serif",
    "mono": "\"JetBrains Mono\", ui-monospace, \"SF Mono\", Menlo, monospace",
    "scale": ["0.75rem","0.875rem","1rem","1.125rem","1.25rem","1.5rem","1.875rem","2.25rem","3rem"]
  },
  "radii": { "sm": "6px", "md": "8px", "lg": "12px", "xl": "16px", "full": "9999px" },
  "spacing": { "base": 4 },
  "shadows": {
    "sm": "0 1px 2px 0 rgb(15 23 42 / 0.06)",
