# ───────────────────────── 23 Telecom Help Desk — environment ─────────────────────────
# Copy to .env (root) for docker-compose, and into apps/api/.env for local dev.

# ── Core ──
NODE_ENV=development
TELECOM_HD_BRAND_NAME="23 Telecom Help Desk"
TELECOM_HD_API_PORT=4000
TELECOM_HD_WEB_PORT=3000
TELECOM_HD_PUBLIC_URL=http://localhost:3000
TELECOM_HD_API_URL=http://localhost:4000

# ── Database (PostgreSQL 16) ──
TELECOM_HD_DB_HOST=postgres
TELECOM_HD_DB_PORT=5432
TELECOM_HD_DB_USER=telecom_hd
TELECOM_HD_DB_PASSWORD=telecom_hd_dev
TELECOM_HD_DB_NAME=telecom_hd
DATABASE_URL=postgresql://telecom_hd:telecom_hd_dev@postgres:5432/telecom_hd?schema=public

# ── Redis / BullMQ ──
TELECOM_HD_REDIS_HOST=redis
TELECOM_HD_REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# ── Auth ──
TELECOM_HD_JWT_ACCESS_SECRET=change-me-access-secret-at-least-32chars
TELECOM_HD_JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32chars
TELECOM_HD_JWT_ACCESS_TTL=900          # 15m (seconds)
TELECOM_HD_JWT_REFRESH_TTL=2592000     # 30d (seconds)

# ── Outbound mail (SMTP / Nodemailer) — defaults to MailHog in compose ──
TELECOM_HD_SMTP_HOST=mailhog
TELECOM_HD_SMTP_PORT=1025
TELECOM_HD_SMTP_SECURE=false
TELECOM_HD_SMTP_USER=
TELECOM_HD_SMTP_PASSWORD=
TELECOM_HD_MAIL_FROM="23 Telecom Help Desk <support@23telecom.example>"

# ── Inbound mail (IMAP poller / imapflow) — disabled by default ──
TELECOM_HD_IMAP_ENABLED=false
TELECOM_HD_IMAP_HOST=
TELECOM_HD_IMAP_PORT=993
TELECOM_HD_IMAP_USER=
TELECOM_HD_IMAP_PASSWORD=
TELECOM_HD_IMAP_TLS=true

# ── Observability ──
TELECOM_HD_LOG_LEVEL=info
TELECOM_HD_OTEL_ENABLED=false
TELECOM_HD_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ── Alaris integration (STUB) ──
TELECOM_HD_ALARIS_WEBHOOK_SECRET=alaris-dev-secret-change-me-0000

# ── File uploads ──
TELECOM_HD_UPLOAD_DIR=/app/uploads
TELECOM_HD_UPLOAD_MAX_SIZE_MB=25

# ── Field-level encryption (AES-256-GCM) — optional; enables IMAP password encryption ──
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# TELECOM_HD_FIELD_ENCRYPTION_KEY=
