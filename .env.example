# ───────────────────────── 23 Telecom Help Desk — environment ─────────────────────────
# Copy to .env (root) for docker-compose, and into apps/api/.env for local dev.

# ── Core ──
NODE_ENV=development
TELECOM_HD_BRAND_NAME="23 Telecom Help Desk"
TELECOM_HD_API_PORT=4000
TELECOM_HD_WEB_PORT=3000
TELECOM_HD_PUBLIC_URL=http://localhost:3000
TELECOM_HD_API_URL=http://localhost:4000

# ── Database (PostgreSQL 16) ──
TELECOM_HD_DB_HOST=postgres
TELECOM_HD_DB_PORT=5432
TELECOM_HD_DB_USER=telecom_hd
TELECOM_HD_DB_PASSWORD=telecom_hd_dev
TELECOM_HD_DB_NAME=telecom_hd
DATABASE_URL=postgresql://telecom_hd:telecom_hd_dev@postgres:5432/telecom_hd?schema=public

# ── Redis / BullMQ ──
TELECOM_HD_REDIS_HOST=redis
TELECOM_HD_REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# ── Auth ──
TELECOM_HD_JWT_ACCESS_SECRET=change-me-access-secret-at-least-32chars
TELECOM_HD_JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32chars
TELECOM_HD_JWT_ACCESS_TTL=900          # 15m (seconds)
TELECOM_HD_JWT_REFRESH_TTL=2592000     # 30d (seconds)

# ── Outbound mail (SMTP / Nodemailer) — defaults to MailHog in compose ──
TELECOM_HD_SMTP_HOST=mailhog
TELECOM_HD_SMTP_PORT=1025
TELECOM_HD_SMTP_SECURE=false
TELECOM_HD_SMTP_USER=
TELECOM_HD_SMTP_PASSWORD=
TELECOM_HD_MAIL_FROM="23 Telecom Help Desk <support@23telecom.example>"
# Physical SMTP sends remain blocked unless an operator explicitly opens this gate.
# Keep false while configuring/testing mail credentials.
TELECOM_HD_OUTBOUND_DELIVERY_ENABLED=false
# Leave blank in normal operation. During an attended SMTP canary, scope delivery to one
# existing OutboundEmail CUID so older durable outbox rows remain untouched.
TELECOM_HD_OUTBOUND_CANARY_EMAIL_ID=
# Pair with the selected OutboundEmail CUID. Runtime requires the durable command to have exactly
# this one normalized recipient before SMTP delivery; leave both canary values blank normally.
TELECOM_HD_OUTBOUND_CANARY_RECIPIENT=

# ── Inbound mail (IMAP poller / imapflow) — disabled by default ──
# Master cutover/canary gate: blocks IMAP, PIPE acceptance and ledger drain. Keep false
# for every code/migration deploy; set true only during an attended inbound canary.
TELECOM_HD_INBOUND_DELIVERY_ENABLED=false
# Leave both normal-canary selectors blank in normal operation. An attended normal-delivery
# canary is promotion-only: it processes one reviewed CAPTURED delivery in one queue, and never
# polls IMAP/accepts PIPE or drains a queue backlog.
TELECOM_HD_INBOUND_NORMAL_CANARY_QUEUE_ID=
TELECOM_HD_INBOUND_NORMAL_CANARY_DELIVERY_ID=
# Test-only durable receive mode. It is mutually exclusive with normal delivery and
# accepts one selected TLS-enabled IMAP queue as CAPTURED (no ticket/post/attachment/autoreply/
# outbound work). PIPE is always 503 while this mode is active.
TELECOM_HD_INBOUND_CAPTURE_ONLY_ENABLED=false
TELECOM_HD_INBOUND_CAPTURE_QUEUE_ID=
# Exactly one durable CAPTURED row on the selected IMAP test queue; this is not a bulk import switch.
TELECOM_HD_INBOUND_CAPTURE_MAX_MESSAGES=1
TELECOM_HD_IMAP_ENABLED=false
TELECOM_HD_IMAP_HOST=
TELECOM_HD_IMAP_PORT=993
TELECOM_HD_IMAP_USER=
TELECOM_HD_IMAP_PASSWORD=
TELECOM_HD_IMAP_TLS=true
# First-connect baseline: FROM_NOW (record high-water, import nothing) or BACKFILL
# (also ingest the N most-recent existing messages). Never imports the whole mailbox.
TELECOM_HD_IMAP_BOOTSTRAP_POLICY=FROM_NOW
TELECOM_HD_IMAP_BACKFILL_LIMIT=0
# Inbound processing attempts before a delivery is QUARANTINED (raw MIME kept for replay).
TELECOM_HD_INBOUND_MAX_ATTEMPTS=5
# Raw-MIME retention (days). A terminal PROCESSED/SKIPPED delivery older than this has its
# inline raw MIME pruned (metadata + contentHash kept) to bound ledger growth. QUARANTINED
# and CAPTURED deliveries are never pruned automatically (raw MIME is needed for review/replay).
# 0 disables pruning.
TELECOM_HD_INBOUND_RAW_RETENTION_DAYS=30
# ── Observability ──
TELECOM_HD_LOG_LEVEL=info
TELECOM_HD_OTEL_ENABLED=false
TELECOM_HD_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ── Alaris integration (STUB) ──
TELECOM_HD_ALARIS_WEBHOOK_SECRET=alaris-dev-secret-change-me-0000

# ── Inbound mail webhook (MTA/PIPE delivery → POST /api/inbound/pipe) ──
# Shared secret sent as the x-inbound-secret header by the pipe script.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TELECOM_HD_INBOUND_WEBHOOK_SECRET=inbound-dev-secret-change-me-0000

# ── File uploads ──
TELECOM_HD_UPLOAD_DIR=/app/uploads
TELECOM_HD_UPLOAD_MAX_SIZE_MB=25
TELECOM_HD_UPLOAD_TOTAL_MAX_SIZE_MB=50
TELECOM_HD_UPLOAD_REQUEST_MAX_SIZE_MB=51
# The one canonical inbound cap: applies both to PIPE HTTP ingress and IMAP fetches.
# Keep it at or below the route-specific reverse-proxy/MTA body limit.
TELECOM_HD_INBOUND_MAX_SIZE_MB=35
TELECOM_HD_ORPHAN_ATTACHMENT_TTL_HOURS=24
TELECOM_HD_ORPHAN_ATTACHMENT_MAX_COUNT=2000
TELECOM_HD_ORPHAN_ATTACHMENT_MAX_SIZE_MB=2048
TELECOM_HD_UPLOAD_MIN_FREE_DISK_MB=5120
TELECOM_HD_ATTACHMENT_CLEANUP_MAX_ITEMS=1000
TELECOM_HD_ATTACHMENT_CLEANUP_MAX_RUN_SECONDS=120
TELECOM_HD_CLIENT_PORTAL_ENABLED=false
TELECOM_HD_CLIENT_UPLOAD_ENABLED=false
TELECOM_HD_PUBLIC_TICKET_CREATE_ENABLED=false
TELECOM_HD_PUBLIC_UPLOAD_ENABLED=false
TELECOM_HD_CLAMAV_ENABLED=false

# ── Field-level encryption (AES-256-GCM) — REQUIRED in production ──
# Development/test may omit it, but production startup and preflight reject a
# missing or malformed key. Production deploys verify the same key as the
# running API before quiesce; routine field-key rotation is not supported.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# TELECOM_HD_FIELD_ENCRYPTION_KEY=
