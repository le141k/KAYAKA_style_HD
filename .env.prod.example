# ─────────────────────────────────────────────────────────────────────────────
# PRODUCTION env template — copy to `.env.prod` and replace EVERY placeholder.
#   cp .env.prod.example .env.prod   &&   $EDITOR .env.prod
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build
#
# The API REFUSES TO BOOT in production with the placeholder secrets below
# (see configuration.ts assertProductionSecrets): change-me / 0000 / example /
# dev-secret are all rejected. Generate strong values:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=production

# Public origin the browser uses (baked into the web build at NEXT_PUBLIC_API_URL).
TELECOM_HD_PUBLIC_URL=https://help.example.com
NEXT_PUBLIC_API_URL=https://help.example.com

# ── Database (use a strong password) ──
TELECOM_HD_DB_USER=telecom_hd
TELECOM_HD_DB_PASSWORD=CHANGE_ME_strong_db_password
TELECOM_HD_DB_NAME=telecom_hd

# ── JWT secrets — MUST be strong + distinct (placeholders below are REJECTED) ──
TELECOM_HD_JWT_ACCESS_SECRET=change-me-access-secret-at-least-32chars
TELECOM_HD_JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32chars
TELECOM_HD_JWT_ACCESS_TTL=900
TELECOM_HD_JWT_REFRESH_TTL=2592000

# ── Real SMTP relay (NOT MailHog) ──
TELECOM_HD_SMTP_HOST=smtp.example.com
TELECOM_HD_SMTP_PORT=587
TELECOM_HD_SMTP_SECURE=true
TELECOM_HD_SMTP_USER=apikey
TELECOM_HD_SMTP_PASSWORD=CHANGE_ME_smtp_password
TELECOM_HD_MAIL_FROM="23 Telecom Help Desk <support@example.com>"

# ── Alaris webhook — REJECTED while it contains "change-me"/"0000" ──
TELECOM_HD_ALARIS_WEBHOOK_SECRET=alaris-dev-secret-change-me-0000

# ── Optional field-encryption key (64 hex / 256-bit) for IMAP passwords ──
# TELECOM_HD_FIELD_ENCRYPTION_KEY=

TELECOM_HD_LOG_LEVEL=info
TELECOM_HD_UPLOAD_DIR=/app/uploads
TELECOM_HD_UPLOAD_MAX_SIZE_MB=25

# Demo seed is OFF in prod. seed.ts hard-refuses unless you set TELECOM_HD_SEED=1
# (NOT recommended — it creates the known-password demo admin).
