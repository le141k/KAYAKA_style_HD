# ─────────────────────────────────────────────────────────────────────────────
# PRODUCTION env template — copy to `.env.prod` and replace EVERY placeholder.
#   cp .env.prod.example .env.prod   &&   $EDITOR .env.prod
#   Follow docs/DEPLOY.md and run scripts/deploy-prod.sh. Never start this file
#   with a direct `docker compose up` on production.
#
# The API REFUSES TO BOOT in production with the placeholder secrets below
# (see configuration.ts assertProductionSecrets): change-me / 0000 / example /
# dev-secret are all rejected. Generate strong values:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=production
# Immutable API/web image tag for this checkout (normally the 12-char git SHA).
TELECOM_HD_RELEASE=SET_TO_GIT_SHA

# Public origin used for secure cookies, CSRF and generated links.
TELECOM_HD_PUBLIC_URL=https://help.example.com
# Empty is the recommended same-origin browser API base. Both NEXT_PUBLIC_* values
# are build-time inputs: rebuild the web image after changing either one.
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=CHANGE_ME_turnstile_site_key
# Bare host for the Caddy reverse proxy auto-TLS (no scheme).
DOMAIN=help.example.com

# ── Database (use a strong password) ──
TELECOM_HD_DB_USER=telecom_hd
TELECOM_HD_DB_PASSWORD=CHANGE_ME_strong_db_password
TELECOM_HD_DB_NAME=telecom_hd

# ── Redis password (required in prod; used by both the redis service and REDIS_URL) ──
TELECOM_HD_REDIS_PASSWORD=CHANGE_ME_strong_redis_password

# ── JWT secrets — MUST be strong + distinct (placeholders below are REJECTED) ──
TELECOM_HD_JWT_ACCESS_SECRET=change-me-access-secret-at-least-32chars
TELECOM_HD_JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32chars
TELECOM_HD_JWT_ACCESS_TTL=900
TELECOM_HD_JWT_REFRESH_TTL=2592000

# ── Real SMTP relay (NOT MailHog) ──
# SECURE: false for port 587 (STARTTLS) — true ONLY for port 465 (implicit TLS).
TELECOM_HD_SMTP_HOST=smtp.example.com
TELECOM_HD_SMTP_PORT=587
TELECOM_HD_SMTP_SECURE=false
TELECOM_HD_SMTP_USER=apikey
TELECOM_HD_SMTP_PASSWORD=CHANGE_ME_smtp_password
TELECOM_HD_MAIL_FROM="23 Telecom Help Desk <support@example.com>"

# ── Alaris webhook — generate a strong secret (the dev default is REJECTED at boot) ──
TELECOM_HD_ALARIS_WEBHOOK_SECRET=CHANGE_ME_strong_alaris_webhook_secret

# ── Inbound mail webhook (POST /api/inbound/pipe) — REQUIRED in prod; the dev
#    default is REJECTED at boot, so set a strong value even if you only use IMAP. ──
TELECOM_HD_INBOUND_WEBHOOK_SECRET=CHANGE_ME_strong_inbound_webhook_secret

# ── Field-encryption key (64 hex / 256-bit) — REQUIRED for every production
#    release. Keep the same key across normal deploys: routine rotation is not
#    supported and the deploy gate rejects a mismatch with the running API.
#    Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TELECOM_HD_FIELD_ENCRYPTION_KEY=CHANGE_ME_64_hex_chars

# Bootstrap credentials must NOT be stored here. On the first internal deploy,
# scripts/bootstrap-admin.sh prompts for them and uses a removed one-shot container.

TELECOM_HD_LOG_LEVEL=info
# The production API volume is mounted only at this exact path. Do not change it.
TELECOM_HD_UPLOAD_DIR=/app/uploads
TELECOM_HD_UPLOAD_MAX_SIZE_MB=25
TELECOM_HD_UPLOAD_TOTAL_MAX_SIZE_MB=50
TELECOM_HD_UPLOAD_REQUEST_MAX_SIZE_MB=51
TELECOM_HD_INBOUND_MAX_SIZE_MB=35
TELECOM_HD_ORPHAN_ATTACHMENT_TTL_HOURS=24
TELECOM_HD_ORPHAN_ATTACHMENT_MAX_COUNT=2000
TELECOM_HD_ORPHAN_ATTACHMENT_MAX_SIZE_MB=2048
TELECOM_HD_UPLOAD_MIN_FREE_DISK_MB=5120
TELECOM_HD_ATTACHMENT_CLEANUP_MAX_ITEMS=1000
TELECOM_HD_ATTACHMENT_CLEANUP_MAX_RUN_SECONDS=120

# ── Inbound IMAP global safety gates ──
# Keep polling OFF until the mandatory IMAP/live-PostgreSQL gates and a canary
# queue are green. Queue host/port/credentials live in the database, not here.
TELECOM_HD_IMAP_ENABLED=false
# First connect records the current high-water and imports nothing by default.
# BACKFILL requires an explicit non-zero bounded limit (max 10000).
TELECOM_HD_IMAP_BOOTSTRAP_POLICY=FROM_NOW
TELECOM_HD_IMAP_BACKFILL_LIMIT=0
TELECOM_HD_INBOUND_MAX_ATTEMPTS=5
# Terminal processed/skipped raw MIME retention; QUARANTINED raw MIME is kept.
TELECOM_HD_INBOUND_RAW_RETENTION_DAYS=30

# ── Verified client-portal read/session gate. Leave OFF until magic-link delivery,
#    edge IP trust, abuse controls and production smoke are all green.
TELECOM_HD_CLIENT_PORTAL_ENABLED=false
# Independent verified-client upload switch. Keep false to preserve client ticket
# reads/replies without accepting new attachment bytes during an incident.
TELECOM_HD_CLIENT_UPLOAD_ENABLED=false

# Independent anonymous public-write kill switches. Leave both false until the edge,
# Turnstile hostname/key pair and production smoke are verified.
TELECOM_HD_PUBLIC_TICKET_CREATE_ENABLED=false
TELECOM_HD_PUBLIC_UPLOAD_ENABLED=false
TELECOM_HD_TURNSTILE_SECRET=CHANGE_ME_turnstile_secret
TELECOM_HD_TURNSTILE_HOSTNAME=help.example.com

# Private ClamAV service. Malware scanning is mandatory for every production
# attachment source; always launch production with the scanner profile.
TELECOM_HD_CLAMAV_ENABLED=true
TELECOM_HD_CLAMAV_HOST=clamav
TELECOM_HD_CLAMAV_PORT=3310
TELECOM_HD_CLAMAV_TIMEOUT_MS=15000
COMPOSE_PROFILES=scanner

# Prisma connection pool size (api handlers + BullMQ workers share it).
TELECOM_HD_DB_POOL=20

# Demo seed is OFF in prod. seed.ts hard-refuses unless you set TELECOM_HD_SEED=1
# (NOT recommended — it creates the known-password demo admin).
