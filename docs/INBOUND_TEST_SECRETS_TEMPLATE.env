# Test-only mailbox settings. Copy this file to an owner-only local path outside
# the repository (for example `~/.config/23telecom-helpdesk/inbound-test.env`),
# fill it there, and never commit or paste its values into chat, tickets, or Git.
#
# SMTP is OUTBOUND only. It is configured now, but the release keeps physical
# delivery disabled until an attended one-message outbound canary is approved.
TELECOM_HD_SMTP_HOST=
# 587 => STARTTLS => false; 465 => implicit TLS => true
TELECOM_HD_SMTP_PORT=587
TELECOM_HD_SMTP_SECURE=false
TELECOM_HD_SMTP_USER=
TELECOM_HD_SMTP_PASSWORD=
TELECOM_HD_MAIL_FROM="23 Telecom NOC <noc@23telecom.example>"

# IMAP is INBOUND. These values are used only to configure one dedicated test
# queue after the capture-only release is deployed. The application never reads
# this sidecar file directly. Do not use a shared Inbox: create a separate,
# empty folder/label and select that exact folder in the queue's `mailbox` field.
TEST_IMAP_HOST=
TEST_IMAP_PORT=993
TEST_IMAP_USERNAME=noc@23telecom.example
TEST_IMAP_PASSWORD=
TEST_IMAP_USE_TLS=true
TEST_IMAP_MAILBOX=Helpdesk Test

# Leave blank for now. The admin UI creates the dedicated test queue and returns
# its numeric id; capture-only mode will accept no other queue. The attended test
# permits exactly one captured message; keep all normal inbound/outbound gates false.
TEST_CAPTURE_QUEUE_ID=

# The application-side capture ceiling is deliberately 1. It is written by the
# local provisioning flow into ignored .env, never stored alongside credentials.
# TELECOM_HD_INBOUND_CAPTURE_MAX_MESSAGES=1
