// 23 Telecom Help Desk — data model
// Modern, normalized rewrite of the Kayako Classic `kayako_fusion` schema.
// Key modernizations vs. Kayako:
//   * real foreign keys & referential integrity (Kayako had none)
//   * DateTime instead of unix-int columns
//   * custom fields as JSONB (`customFields`) instead of the EAV value table
//   * attachments referenced by storage key (disk/object store), not chunked BLOBs
//   * denormalized `*title` mirror columns dropped (joined live instead)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ───────────────────────────── enums ─────────────────────────────

enum DepartmentType {
  PUBLIC
  PRIVATE
}

enum UserGroupType {
  GUEST
  REGISTERED
}

// 23 Telecom is a broker in the middle: customers (CLIENT) email in, 23T (INTERNAL)
// works the issue and contacts carriers (SUPPLIER). Used to classify orgs on import.
enum OrgType {
  CLIENT
  SUPPLIER
  INTERNAL
}

enum ActorType {
  STAFF
  USER
  SYSTEM
}

enum CreationMode {
  WEB
  EMAIL
  API
  STAFF
  ALARIS
}

enum CustomFieldScope {
  TICKET
  USER
  STAFF
  ORGANIZATION
}

enum CustomFieldType {
  TEXT
  TEXTAREA
  PASSWORD
  CHECKBOX
  RADIO
  SELECT
  MULTISELECT
  DATE
  NUMBER
  FILE
  CUSTOM
}

enum SlaTargetType {
  FIRST_RESPONSE
  RESOLUTION
}

enum EmailQueueType {
  IMAP
  POP3
  PIPE
}

// Inbound delivery ledger — durable record of every accepted inbound message so
// processing failures never lose mail (raw MIME is replayable) and re-delivery is
// idempotent by a unique transport key.
enum InboundTransport {
  IMAP
  PIPE
}

enum InboundDeliveryState {
  ACCEPTED // durably recorded (raw MIME stored); not yet processed
  // Capture-only acceptance. Raw RFC822 bytes are durable, but this state is never
  // selected by the drain and cannot become processable merely by a later config flip.
  // An operator must explicitly promote one row through the audited capture API.
  CAPTURED
  PROCESSING // claimed by a drain worker
  PROCESSED // business op committed (ticket/post created or threaded)
  RETRY // transient failure; retried with backoff, never discarded
  QUARANTINED // permanent failure / attempts exhausted; needs operator, raw MIME retained
  SKIPPED // intentionally not ticketed (loop/bounce/parser-ignore/duplicate)
}

// Durable state machine for a large raw-MIME staging reservation. Acceptance may only
// consume ACTIVE; it writes COMMITTED in the same transaction as InboundDelivery. A reaper
// commits REAPING before any filesystem delete, so a database rollback cannot revive a stage
// whose bytes have already been removed.
enum InboundRawMimeStagingState {
  ACTIVE
  COMMITTED
  REAPING
}

// Per-queue IMAP sync health. NEEDS_RECONCILIATION halts polling (fail-closed) after a
// UIDVALIDITY change so an operator explicitly chooses FROM_NOW or a bounded BACKFILL.
// BOOTSTRAPPING is transient: an operator reconcile holds the queue here while it captures
// UIDVALIDITY/UIDNEXT under the IMAP mailbox lock.  The same request durably commits that
// exact baseline before it returns OK, so health never reports a cursor before it exists.
enum EmailQueueSyncState {
  OK
  BOOTSTRAPPING
  NEEDS_RECONCILIATION
}

// Why an IMAP queue is halted/reconciling.  This is deliberately durable and
// server-side: the UI must never infer that a dangerous resume is safe from a
// free-form lastError string.
enum EmailQueueReconcileCause {
  LEGACY_MIGRATION
  UIDVALIDITY_CHANGED
  MAILBOX_IDENTITY_CHANGED
  MANUAL_FORCE
  TRANSPORT_COLLISION
  UNKNOWN
}

enum FlagType {
  NONE
  PURPLE
  ORANGE
  GREEN
  YELLOW
  RED
  BLUE
}

enum RecipientRole {
  CC
  BCC
}

// Durable transactional outbox for staff-originated public email. A post is not
// reported as emailed merely because a Redis job was accepted: SENT means the
// configured SMTP transport accepted the message with its persisted Message-ID.
enum OutboundEmailState {
  QUEUED
  PROCESSING
  SENT
  RETRY
  FAILED
  AMBIGUOUS
}

// The persisted command kind determines both its delivery semantics and the
// safe projections we update after SMTP acceptance.  Automated customer mail
// must not masquerade as a human first response.
enum OutboundEmailKind {
  STAFF_REPLY
  AUTORESPONDER
  AUTO_CLOSE
  WORKFLOW
  REPORT
  // Staff-facing, machine-generated alerts (assignment, watcher reply, SLA).
  // They remain durable commands rather than an inline SMTP side effect.
  INTERNAL_NOTIFICATION
}

/** Durable, ticket-transactional trigger for customer-facing workflow email actions. */
enum WorkflowEmailEventState {
  PENDING
  PROCESSING
  PROCESSED
  RETRY
  QUARANTINED
}

// Kept separate from TicketRecipient's CC/BCC roles because every immutable
// outbox snapshot also owns its visible To recipients.
enum OutboundRecipientRole {
  TO
  CC
  BCC
}

enum ParserRuleType {
  PRE_PARSE
  POST_PARSE
}

enum ParserMatchType {
  ALL
  ANY
}

// ───────────────────────────── staff / RBAC ─────────────────────────────

model StaffGroup {
  id          Int      @id @default(autoincrement())
  title       String
  isAdmin     Boolean  @default(false)
  // RBAC: list of permission keys (see apps/api/src/auth/permissions.ts catalog)
  permissions String[] @default([])
  staff       Staff[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Staff {
  id              Int       @id @default(autoincrement())
  email           String    @unique
  username        String    @unique
  firstName       String
  lastName        String
  passwordHash    String
  designation     String    @default("")
  signature       String    @default("")
  mobileNumber    String    @default("")
  timezone        String    @default("UTC")
  isEnabled       Boolean   @default(true)
  // Bumped on every security-relevant change (password/disable/group/permission).
  // Embedded in each access token as the `av` claim; the JWT guard rejects any token
  // whose `av` no longer matches, so revocation is immediate (GOAL_PUBLIC_SECURITY S3).
  authVersion     Int       @default(0)
  staffGroup      StaffGroup @relation(fields: [staffGroupId], references: [id])
  staffGroupId    Int
  // Explicit allow-list of departments this non-admin agent can act in. An
  // empty list grants no ticket-department access; only staffGroup.isAdmin is
  // globally unrestricted.
  departments     DepartmentStaff[]
  ownedTickets    Ticket[]  @relation("TicketOwner")
  posts           TicketPost[]
  notes           TicketNote[]
  auditLogs       TicketAuditLog[]
  refreshTokens   RefreshToken[]
  watching        TicketWatcher[]
  timeEntries     TimeEntry[]
  followUps       FollowUp[]
  savedViews      SavedView[]
  ownedReportSchedules ReportSchedule[] @relation("ReportScheduleOwner")
  lastLoginAt     DateTime?
  // D2 — per-account brute-force lockout (complements the per-IP rate limiter).
  failedLoginAttempts Int    @default(0)
  lockedUntil     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([staffGroupId])
  // C5: trigram GIN for ILIKE staff name search.
  @@index([firstName(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([lastName(ops: raw("gin_trgm_ops"))], type: Gin)
}

model RefreshToken {
  id        String   @id @default(uuid())
  staff     Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  staffId   Int
  // Opaque rotation identifiers (S3-3): `jti` is the refresh JWT's id, looked up
  // directly (no Argon2 scan); `familyId` groups a rotation chain so a detected replay
  // can revoke the whole family.
  jti       String   @unique
  familyId  String
  // The staff authVersion this token was issued under. A refresh whose row.authVersion
  // no longer matches the staff record is rejected — so logout-all / password / group
  // changes can't be outrun by a concurrently-rotating session (S3, race fix).
  authVersion Int    @default(0)
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@index([staffId])
  // Load: bound the refresh-rotation scan + support expired-token cleanup.
  @@index([staffId, revokedAt])
  @@index([staffId, expiresAt])
  @@index([familyId])
}

model PasswordReset {
  id          Int       @id @default(autoincrement())
  staffId     Int
  // Security-state stamp at issuance; reset requires an exact Staff.authVersion match.
  authVersion Int       @default(-1)
  tokenHash   String    @unique   // sha256 hex of the raw token
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([staffId])
  @@index([expiresAt])
  @@index([staffId, usedAt])
  // A raw migration adds a partial UNIQUE(staffId) WHERE usedAt IS NULL;
  // Prisma schema syntax cannot represent partial indexes.
}

// Append-only audit trail for RBAC / staff-account changes: who did what to which
// staff member or group. `actorStaffId` is a plain int (no FK) so rows survive even
// if the actor is later removed; `metadata` carries a small JSON diff/summary.
model RbacAuditLog {
  id           Int      @id @default(autoincrement())
  actorStaffId Int?     // null for system/bootstrap actions
  actorEmail   String   @default("")
  action       String   // e.g. staff.create, staff.role_change, staff.password_reset, staff.disable, group.update
  targetType   String   // 'staff' | 'group'
  targetId     Int?
  targetLabel  String   @default("")
  metadata     Json     @default("{}")
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([actorStaffId])
  @@index([targetType, targetId])
}

// ─── Verified client (customer) auth — GOAL_PUBLIC_SECURITY S2 ───
// Replaces "knowing an email" with a verified, revocable session bound to a stable
// User.id. Only SHA-256 hashes of cryptographically-random tokens are stored; the raw
// token is never persisted. `email` is an audit snapshot, NEVER the authorization key.

model ClientLoginToken {
  id                String    @id @default(uuid())
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId            Int
  // Version of the client identity at issuance. Verification requires this to equal
  // User.clientAuthVersion, so disable/re-enable and email changes burn old links.
  clientAuthVersion Int       @default(-1)
  tokenHash         String    @unique // sha256 hex of the single-use raw login token
  email             String // normalized-email snapshot (audit only)
  expiresAt         DateTime
  usedAt            DateTime?
  createdAt         DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model ClientSession {
  id                String    @id @default(uuid())
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId            Int
  // Must match User.clientAuthVersion on every resolution.
  clientAuthVersion Int       @default(-1)
  tokenHash         String    @unique // sha256 hex of the raw session cookie value
  email             String // normalized-email snapshot (audit only)
  expiresAt         DateTime
  revokedAt         DateTime?
  createdAt         DateTime  @default(now())
  lastSeenAt        DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// ───────────────────────────── customers / orgs ─────────────────────────────

model UserGroup {
  id        Int           @id @default(autoincrement())
  title     String
  type      UserGroupType @default(REGISTERED)
  isMaster  Boolean       @default(false)
  users     User[]
  createdAt DateTime      @default(now())
}

model Organization {
  id          Int      @id @default(autoincrement())
  // Kayako source id — set by the importer for idempotent upserts/FK resolution.
  kayakoId    Int?     @unique
  orgType     OrgType  @default(CLIENT)
  name        String
  address     String   @default("")
  city        String   @default("")
  state       String   @default("")
  postalCode  String   @default("")
  country     String   @default("")
  phone       String   @default("")
  website     String   @default("")
  slaPlan     SlaPlan? @relation(fields: [slaPlanId], references: [id])
  slaPlanId   Int?
  users       User[]
  customFields Json    @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // C5: trigram GIN for ILIKE org name search (OrganizationsService.list).
  @@index([name(ops: raw("gin_trgm_ops"))], type: Gin)
}

model User {
  id             Int           @id @default(autoincrement())
  kayakoId       Int?          @unique
  fullName       String
  phone          String        @default("")
  designation    String        @default("")
  // nullable: many customers are created from inbound email without a password
  passwordHash      String?
  isEnabled         Boolean       @default(true)
  // Bumped whenever the verified client identity changes (enable state or email set).
  // Login tokens and sessions are stamped with this value for durable revocation.
  clientAuthVersion Int           @default(0)
  isValidated       Boolean       @default(false)
  timezone       String        @default("UTC")
  userGroup      UserGroup?    @relation(fields: [userGroupId], references: [id])
  userGroupId    Int?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  organizationId Int?
  emails         UserEmail[]
  tickets        Ticket[]
  loginTokens    ClientLoginToken[]
  sessions       ClientSession[]
  posts          TicketPost[]
  geoip          Json?
  customFields   Json          @default("{}")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([organizationId])
  // C5: trigram GIN for ILIKE user search (UsersService.list). Needs pg_trgm (enabled).
  @@index([fullName(ops: raw("gin_trgm_ops"))], type: Gin)
}

model UserEmail {
  id        Int     @id @default(autoincrement())
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  email     String  @unique
  isPrimary Boolean @default(false)

  @@index([userId])
}

// ───────────────────────────── departments ─────────────────────────────

model Department {
  id           Int            @id @default(autoincrement())
  title        String
  type         DepartmentType @default(PUBLIC)
  app          String         @default("tickets")
  isDefault    Boolean        @default(false)
  displayOrder Int            @default(0)
  parent       Department?    @relation("DepartmentTree", fields: [parentId], references: [id])
  parentId     Int?
  children     Department[]   @relation("DepartmentTree")
  tickets      Ticket[]
  staff        DepartmentStaff[]
  emailQueues  EmailQueue[]
  routedInboundDeliveries InboundDelivery[]    @relation("InboundDeliveryRoutedDepartment")
  inboundMessageClaims    InboundMessageClaim[] @relation("InboundMessageClaimDepartment")
  createdAt    DateTime       @default(now())
}

model DepartmentStaff {
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  departmentId Int
  staff        Staff      @relation(fields: [staffId], references: [id], onDelete: Cascade)
  staffId      Int

  @@id([departmentId, staffId])
}

// ───────────────────────────── ticket reference data ─────────────────────────────

model TicketStatus {
  id            Int      @id @default(autoincrement())
  title         String
  displayOrder  Int      @default(0)
  markAsResolved Boolean @default(false)
  color         String   @default("")
  bgColor       String   @default("")
  displayIcon   String   @default("")
  triggersSurvey Boolean @default(false)
  isDefault     Boolean  @default(false)
  tickets       Ticket[]
}

model TicketPriority {
  id           Int      @id @default(autoincrement())
  title        String
  displayOrder Int      @default(0)
  color        String   @default("")
  bgColor      String   @default("")
  tickets      Ticket[]
}

model TicketType {
  id           Int      @id @default(autoincrement())
  title        String
  displayOrder Int      @default(0)
  displayIcon  String   @default("")
  tickets      Ticket[]
}

// ───────────────────────────── tickets ─────────────────────────────

model Ticket {
  id              Int            @id @default(autoincrement())
  kayakoId        Int?           @unique
  mask            String         @unique          // human ID, e.g. TT-000123
  subject         String

  department      Department     @relation(fields: [departmentId], references: [id])
  departmentId    Int
  status          TicketStatus   @relation(fields: [statusId], references: [id])
  statusId        Int
  priority        TicketPriority @relation(fields: [priorityId], references: [id])
  priorityId      Int
  type            TicketType?    @relation(fields: [typeId], references: [id])
  typeId          Int?

  // requester (registered user optional; raw email always captured)
  user            User?          @relation(fields: [userId], references: [id])
  userId          Int?
  requesterName   String         @default("")
  requesterEmail  String         @default("")

  owner           Staff?         @relation("TicketOwner", fields: [ownerStaffId], references: [id])
  ownerStaffId    Int?

  slaPlan         SlaPlan?       @relation(fields: [slaPlanId], references: [id])
  slaPlanId       Int?
  dueAt           DateTime?
  resolutionDueAt DateTime?
  firstResponseAt DateTime?
  resolvedAt      DateTime?
  reopenedAt      DateTime?

  creationMode    CreationMode   @default(WEB)
  creator         ActorType      @default(USER)
  flagType        FlagType       @default(NONE)

  totalReplies    Int            @default(0)
  hasAttachments  Boolean        @default(false)
  hasNotes        Boolean        @default(false)
  isResolved      Boolean        @default(false)
  isEscalated     Boolean        @default(false)
  escalationLevel Int            @default(0)
  wasReopened     Boolean        @default(false)
  isPhoneCall     Boolean        @default(false)
  ipAddress       String         @default("0.0.0.0")

  // threading
  messageId       String?        @default("")

  // merge: when merged, points to surviving ticket
  mergedInto      Ticket?        @relation("TicketMerge", fields: [mergedIntoId], references: [id])
  mergedIntoId    Int?
  mergedFrom      Ticket[]       @relation("TicketMerge")

  customFields    Json           @default("{}")

  posts           TicketPost[]
  effectiveOwnerInboundDeliveries InboundDelivery[] @relation("InboundDeliveryEffectiveOwnerTicket")
  notes           TicketNote[]
  attachments     Attachment[]
  watchers        TicketWatcher[]
  tags            TicketTag[]
  auditLogs       TicketAuditLog[]
  linksFrom       TicketLink[]   @relation("LinkSource")
  linksTo         TicketLink[]   @relation("LinkTarget")
  alarisEvent     AlarisEvent?
  recipients      TicketRecipient[]
  timeEntries     TimeEntry[]
  followUps       FollowUp[]
  workflowEmailEvents WorkflowEmailEvent[]
  slaEscalationEvents SlaEscalationEvent[]
  inboundMessageClaims InboundMessageClaim[] @relation("InboundMessageClaimTicket")
  outboundEmails  OutboundEmail[]

  lastReplyAt     DateTime?
  lastActivityAt  DateTime       @default(now())
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([statusId])
  @@index([departmentId])
  @@index([ownerStaffId])
  @@index([userId])
  @@index([lastActivityAt])
  @@index([createdAt])
  // Load: frequently filtered/sorted columns (list filters, SLA breach scan, reports)
  @@index([priorityId])
  @@index([typeId])
  @@index([isResolved])
  @@index([mergedIntoId])
  @@index([dueAt])
  @@index([resolutionDueAt])
  // Composite for the 60s SLA breach scan (isResolved=false, isEscalated=false, mergedIntoId=null)
  @@index([isResolved, isEscalated, mergedIntoId])
  // Trigram GIN indexes so the list `search` (ILIKE '%term%') uses an index
  // instead of a sequential scan. Requires the pg_trgm extension (prior migration).
  @@index([subject(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([requesterEmail(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([requesterName(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([mask(ops: raw("gin_trgm_ops"))], type: Gin)
}

model TicketPost {
  id           Int        @id @default(autoincrement())
  ticket       Ticket     @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  ticketId     Int
  authorType   ActorType  @default(USER)
  staff        Staff?     @relation(fields: [staffId], references: [id])
  staffId      Int?
  user         User?      @relation(fields: [userId], references: [id])
  userId       Int?
  fullName     String     @default("")
  email        String     @default("")
  subject      String     @default("")
  contents     String     // body (HTML or plaintext per isHtml)
  isHtml       Boolean    @default(true)
  isEmailed    Boolean    @default(false)
  isThirdParty Boolean    @default(false)
  creationMode CreationMode @default(WEB)
  // RFC Message-ID used only for threading. It is deliberately non-unique: an
  // untrusted inbound sender may reuse a staff outbound Message-ID, and that
  // must not suppress the inbound message or prevent it being recorded.
  messageId        String?
  // Idempotency identity assigned only to inbound EMAIL posts. This keeps the
  // inbound deduplication namespace separate from staff/outbound threading IDs.
  // PostgreSQL UNIQUE permits multiple NULLs, so web/staff/API posts leave it null.
  inboundMessageId String?    @unique
  ipAddress    String     @default("0.0.0.0")
  attachments  Attachment[]
  inboundMessageClaims InboundMessageClaim[] @relation("InboundMessageClaimPost")
  outboundEmail OutboundEmail?
  editedAt     DateTime?
  editedByStaffId Int?
  createdAt    DateTime   @default(now())

  @@index([ticketId])
  @@index([messageId])
}

model TicketNote {
  id          Int          @id @default(autoincrement())
  ticket      Ticket       @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  ticketId    Int
  staff       Staff?       @relation(fields: [staffId], references: [id])
  staffId     Int?
  contents    String
  attachments Attachment[]
  createdAt   DateTime     @default(now())

  @@index([ticketId])
}

model Attachment {
  id         Int         @id @default(autoincrement())
  ticket     Ticket?     @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  ticketId   Int?
  post       TicketPost? @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId     Int?
  // U1: note attachments — link to the note that owns this attachment (null = post/ticket-level)
  note       TicketNote? @relation(fields: [noteId], references: [id], onDelete: Cascade)
  noteId     Int?
  fileName   String
  mimeType   String      @default("application/octet-stream")
  size       Int         @default(0)
  sha1       String      @default("")
  storageKey String                       // path/key in object store or disk
  // Per-upload secret for anonymous orphan uploads. The public submit/reply must
  // echo it back to adopt these orphans (prevents cross-submitter IDOR). Cleared
  // once the rows are linked to a post.
  claimToken String?
  // A queued staff email snapshots this attachment's metadata and storage key.
  // AttachmentsService rejects direct manager deletion while a snapshot exists;
  // the relation itself cascades only so ticket/post cascade-deletion can remove
  // the whole coherent graph without a foreign-key deadlock.
  outboundEmailAttachments OutboundEmailAttachment[] @relation("OutboundEmailAttachmentSource")
  createdAt  DateTime    @default(now())

  @@index([ticketId])
  @@index([postId])
  @@index([noteId])
  @@index([claimToken])
}

model TicketWatcher {
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  ticketId Int
  staff    Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)
  staffId  Int

  @@id([ticketId, staffId])
}

model TicketTag {
  id      Int      @id @default(autoincrement())
  name    String   @unique
  tickets Ticket[]
}

model TicketAuditLog {
  id        Int       @id @default(autoincrement())
  ticket    Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  ticketId  Int
  staff     Staff?    @relation(fields: [staffId], references: [id])
  staffId   Int?
  actorType ActorType @default(STAFF)
  action    String                       // e.g. STATUS_CHANGE, ASSIGN, REPLY, MERGE
  field     String?
  oldValue  String?
  newValue  String?
  createdAt DateTime  @default(now())

  @@index([ticketId])
  @@index([createdAt])
}

model TicketLink {
  id        Int    @id @default(autoincrement())
  source    Ticket @relation("LinkSource", fields: [sourceId], references: [id], onDelete: Cascade)
  sourceId  Int
  target    Ticket @relation("LinkTarget", fields: [targetId], references: [id], onDelete: Cascade)
  targetId  Int
  linkType  String @default("related")

  @@unique([sourceId, targetId])
}

model TicketRecipient {
  id       Int           @id @default(autoincrement())
  ticket   Ticket        @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  ticketId Int
  email    String
  role     RecipientRole
  addedAt  DateTime      @default(now())

  @@unique([ticketId, email])
  @@index([ticketId])
}

// ───────────────────────────── SLA / escalation ─────────────────────────────

model SlaSchedule {
  id        Int          @id @default(autoincrement())
  title     String
  // weekly operational hours: { mon: [["09:00","18:00"]], ... }
  workHours Json         @default("{}")
  holidays  SlaHoliday[]
  plans     SlaPlan[]
  createdAt DateTime     @default(now())
}

model SlaHoliday {
  id         Int         @id @default(autoincrement())
  schedule   SlaSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  scheduleId Int
  title      String
  date       DateTime

  @@index([scheduleId])
}

model SlaPlan {
  id                   Int             @id @default(autoincrement())
  title                String
  isEnabled            Boolean         @default(true)
  // criteria for auto-applying the plan (JSON rule set)
  criteria             Json            @default("[]")
  firstResponseSeconds Int?
  resolutionSeconds    Int?
  schedule             SlaSchedule?    @relation(fields: [scheduleId], references: [id])
  scheduleId           Int?
  escalationRules      EscalationRule[]
  tickets              Ticket[]
  organizations        Organization[]
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
}

model EscalationRule {
  id              Int           @id @default(autoincrement())
  slaPlan         SlaPlan       @relation(fields: [slaPlanId], references: [id], onDelete: Cascade)
  slaPlanId       Int
  name            String
  targetType      SlaTargetType @default(FIRST_RESPONSE)
  thresholdSeconds Int          @default(0)
  // actions to run on breach (assign, notify, change priority…)
  actions         Json          @default("[]")
  isEnabled       Boolean       @default(true)

  @@index([slaPlanId])
}

/**
 * One durable, idempotent SLA breach event per ticket/target pair.  The event
 * is claimed in the same transaction as the escalation mutation and any
 * internal-notification outbox commands, so a second scheduler cannot repeat
 * rule effects or silently lose the notification after a process crash.
 */
model SlaEscalationEvent {
  id             String          @id @default(cuid())
  ticket         Ticket          @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  ticketId       Int
  breachType     SlaTargetType
  sourceKey      String          @unique
  outboundEmails OutboundEmail[]
  createdAt      DateTime        @default(now())

  @@unique([ticketId, breachType])
  @@index([ticketId])
}

// ───────────────────────────── workflows / macros ─────────────────────────────

model MacroCategory {
  id      Int     @id @default(autoincrement())
  title   String
  parent  MacroCategory? @relation("MacroTree", fields: [parentId], references: [id])
  parentId Int?
  children MacroCategory[] @relation("MacroTree")
  macros  Macro[]
}

model Macro {
  id         Int            @id @default(autoincrement())
  kayakoId   Int?           @unique
  category   MacroCategory? @relation(fields: [categoryId], references: [id])
  categoryId Int?
  title      String
  subject    String         @default("")
  replyText  String         @default("")
  isHtml     Boolean        @default(false)
  // bulk actions applied with the macro
  actions    Json           @default("[]")
  // shared = visible to all agents; false = owner-only (UI toggle)
  isShared   Boolean        @default(true)
  createdAt  DateTime       @default(now())
}

model Workflow {
  id        Int      @id @default(autoincrement())
  title     String
  criteria  Json     @default("[]")   // condition set
  actions   Json     @default("[]")   // actions to apply
  isEnabled Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Load: every ticket event queries enabled workflows ordered by sortOrder.
  @@index([isEnabled, sortOrder])
}

// ───────────────────────────── mail ─────────────────────────────

model EmailQueue {
  id             Int            @id @default(autoincrement())
  type           EmailQueueType @default(IMAP)
  emailAddress   String         @unique
  host           String         @default("")
  port           Int            @default(993)
  username       String         @default("")
  passwordEnc    String         @default("")   // encrypted at rest
  useTls         Boolean        @default(true)
  // IMAP folder selected for this queue. Keeping it on the queue (rather than assuming
  // INBOX) lets a test/capture queue read a dedicated folder without touching a shared
  // mailbox. A change is treated as a mailbox identity change by the service.
  mailbox        String         @default("INBOX")
  department     Department?    @relation(fields: [departmentId], references: [id])
  departmentId   Int?
  signature      String         @default("")
  // Deterministic owner for a logical message delivered to multiple configured queues.
  // Lower values win; equal priorities break ties by queue id.
  routingPriority Int           @default(100)
  // Kayako `ticketautoresponder`: only send the autoresponder for EMAIL tickets
  // when the receiving queue opts in (noc@/rates@ are OFF in the source system).
  sendAutoresponder Boolean      @default(false)
  // Optimistic configuration version. Every operator edit increments it, so a
  // poller which fetched MIME under an older address/department/policy snapshot
  // cannot accept that mail after the queue has been repointed.
  configGeneration Int           @default(0)
  isEnabled      Boolean        @default(false)
  createdAt      DateTime       @default(now())

  // Durable IMAP poll cursor (replaces the legacy Setting `imap/lastSeenUid:<id>`).
  // `uidValidity` NULL means the queue has never been bootstrapped → the poller sets a
  // synchronous baseline before its first fetch (no historical import). A UIDVALIDITY
  // change flips `syncState` to NEEDS_RECONCILIATION and halts polling (fail-closed).
  lastSeenUid    BigInt              @default(0)
  uidValidity    BigInt?
  syncState      EmailQueueSyncState @default(OK)
  lastError      String?
  // Bumped on every reconcile/rebootstrap. The cursor CAS is gated on this so a stale
  // poller (finishing after a reconcile) can't write a cursor from the old UID space.
  cursorGeneration Int               @default(0)
  // Bumped whenever the IMAP mailbox identity changes (including IMAP <-> non-IMAP
  // transitions). UIDVALIDITY/UID pairs are only meaningful within this epoch.
  mailboxEpoch     Int               @default(1)
  // A halted/reconciling mailbox carries a durable, typed reason. It determines the
  // server-side allowed reconcile modes; never derive safety from lastError text.
  reconcileCause       EmailQueueReconcileCause?
  reconcileRequestedAt DateTime?
  // Per-queue re-bootstrap intent set by an explicit operator reconcile (overrides the
  // global TELECOM_HD_IMAP_BOOTSTRAP_POLICY for THIS queue's next bootstrap). NULL = use
  // the global config. Only consulted while `uidValidity IS NULL` (never bootstrapped).
  bootstrapPolicy       EmailQueueBootstrapPolicy?
  bootstrapBackfillLimit Int?

  // An immutable lifetime fence for an attended capture-only mailbox. It latches before
  // MIME is fetched, so a test folder can never later be reused as normal inbound ingress.
  // There is intentionally no DTO/API field that can clear it: create a fresh queue/folder.
  captureRetiredAt       DateTime?

  // Operator liveness signal (advisory; not part of any cursor/acceptance CAS). These
  // values make a disconnected/stuck poller visible without exposing credentials or raw
  // driver errors. `lastPollAt` is retained for API compatibility; start/completed give
  // the operator an honest distinction between a running and a completed cycle.
  lastConnectionAttemptAt DateTime?
  lastConnectedAt         DateTime?
  lastDisconnectedAt      DateTime?
  lastConnectionErrorAt   DateTime?
  lastPollStartedAt       DateTime?
  lastPollAt              DateTime?
  lastPollCompletedAt     DateTime?
  lastAcceptedAt          DateTime?

  inboundDeliveries InboundDelivery[]
  inboundRawMimeStages InboundRawMimeStaging[]
  routedInboundDeliveries InboundDelivery[] @relation("InboundDeliveryRoutedQueue")
  routedInboundMessageClaims InboundMessageClaim[] @relation("InboundMessageClaimRoutedQueue")
  outboundEmails OutboundEmail[]

  // Kept in sync with the explicit production migration.  This index serves the
  // supervisor's normal-mode query, which must exclude permanently retired
  // capture queues without scanning every enabled IMAP queue.
  @@index([isEnabled, type, captureRetiredAt], map: "EmailQueue_isEnabled_type_captureRetiredAt_idx")
}

/**
 * Immutable, database-backed SMTP command created together with the staff post.
 * BullMQ carries only this row's id as an accelerator; PostgreSQL remains the
 * authoritative queue and is scanned on worker startup/recovery.
 */
model OutboundEmail {
  id            String             @id @default(cuid())
  // Staff/ticket automation rows belong to a ticket; scheduled report commands do not.
  ticket        Ticket?            @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  ticketId      Int?
  // Automated ticket mail has no TicketPost, but is still a first-class durable
  // command tied to the ticket and visible to operators.
  post          TicketPost?        @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId        Int?               @unique
  emailQueue    EmailQueue?        @relation(fields: [emailQueueId], references: [id], onDelete: SetNull)
  emailQueueId  Int?
  reportRun     ReportRun?         @relation("ReportRunOutboundEmail", fields: [reportRunId], references: [id], onDelete: Cascade)
  reportRunId   Int?               @unique
  // SLA notifications are linked to their durable breach event.  This is a
  // many-command relation because one rule/event may notify several staff.
  slaEscalationEvent SlaEscalationEvent? @relation(fields: [slaEscalationEventId], references: [id], onDelete: Cascade)
  slaEscalationEventId String?
  // Command-level idempotency fence for non-post commands (workflow/report). PostgreSQL
  // permits many NULL values, so existing ticket-mail behavior is unchanged.
  idempotencyKey String?           @unique
  kind          OutboundEmailKind  @default(STAFF_REPLY)

  state         OutboundEmailState @default(QUEUED)
  // Generated before the ticket transaction commits. It is reused by every
  // retry/manual retry so an ambiguous SMTP outcome never gets a fresh identity.
  messageId     String             @unique
  fromAddress   String
  replyToAddress String?
  subject       String
  htmlBody      String
  textBody      String
  inReplyTo     String?
  references    String[]           @default([])

  recipients    OutboundEmailRecipient[]
  attachments   OutboundEmailAttachment[]

  attempts      Int                @default(0)
  nextAttemptAt DateTime?
  leaseOwner    String?
  leaseExpiresAt DateTime?
  // Monotonic claim fence. A stale worker may never settle a later worker's lease.
  leaseVersion  Int                @default(0)
  // Bounded/sanitized diagnostic safe for the staff timeline. Never store SMTP
  // credentials, recipient headers or raw message content here.
  lastError     String?
  providerResponse String?
  acceptedAt    DateTime?
  sentAt        DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([ticketId])
  @@index([slaEscalationEventId])
  @@index([state, nextAttemptAt])
  @@index([leaseExpiresAt])
}

/** Recipient snapshot. BCC rows are never projected from staff ticket reads. */
model OutboundEmailRecipient {
  id              Int                   @id @default(autoincrement())
  outboundEmail   OutboundEmail         @relation(fields: [outboundEmailId], references: [id], onDelete: Cascade)
  outboundEmailId String
  email           String
  role            OutboundRecipientRole
  createdAt       DateTime              @default(now())

  @@unique([outboundEmailId, email])
  @@index([outboundEmailId, role])
}

/** Immutable metadata/storage snapshot for a staff reply attachment. */
model OutboundEmailAttachment {
  id                 Int           @id @default(autoincrement())
  outboundEmail      OutboundEmail @relation(fields: [outboundEmailId], references: [id], onDelete: Cascade)
  outboundEmailId    String
  // Cascade permits ticket/post cascade-delete to remove the outbox snapshot first.
  // AttachmentsService separately rejects a manager's direct attachment delete while
  // this relation exists, so a committed queued email cannot lose its bytes.
  sourceAttachment   Attachment    @relation("OutboundEmailAttachmentSource", fields: [sourceAttachmentId], references: [id], onDelete: Cascade)
  sourceAttachmentId Int
  fileName           String
  mimeType           String
  size               Int
  sha1               String
  storageKey         String
  createdAt          DateTime      @default(now())

  @@unique([outboundEmailId, sourceAttachmentId])
  @@index([sourceAttachmentId])
}

/** Per-queue bootstrap intent chosen by an operator reconcile (see EmailQueue). */
enum EmailQueueBootstrapPolicy {
  FROM_NOW
  BACKFILL
}

/** Authoritative lifecycle of a delivery's non-admin mail-operator owner. */
enum InboundDeliveryEffectiveOwnerKind {
  // A captured/truncated delivery whose MIME is never entering normal ticket routing.
  RECEIVING
  // A deterministic queue route or parser-rule target before a ticket exists.
  ROUTED
  // A known ticket; access follows that ticket's current department through the relation.
  TICKET
  // Ownership was not safely resolved. Non-admin mail operators must not see or act on it.
  UNRESOLVED
}

model InboundDelivery {
  id            Int              @id @default(autoincrement())
  transport     InboundTransport
  queue         EmailQueue?      @relation(fields: [queueId], references: [id])
  queueId       Int?

  // Canonical idempotency key — the atomic claim. Unique across all deliveries:
  //   IMAP: `imap:<queueId>:<mailboxEpoch>:<uidValidity>:<uid>`
  //   PIPE: `pipe:<queueId|->:<externalId or sha256:hash>`
  transportKey  String           @unique

  // IMAP transport identity (also stored structured for admin/observability). IMAP UIDs
  // are unsigned 32-bit, so BigInt (not signed 32-bit INTEGER) to avoid overflow.
  // `mailboxEpoch` snapshots the queue's identity generation at acceptance, preventing a
  // new mailbox reusing UIDVALIDITY/UID from colliding with an older mailbox's delivery.
  mailboxEpoch  Int?
  uidValidity   BigInt?
  uid           BigInt?
  // PIPE/MTA transport identity (webhook idempotency id / MTA delivery id)
  externalId    String?

  // Compatibility-only legacy claim. It remains UNIQUE during the expand/contract rollout,
  // but new runtime writes logical identity to `InboundMessageClaim` instead. It MUST NOT be
  // used to collapse separate transport copies after the logical-claim cutover is complete.
  messageId     String?          @unique
  // The real RFC Message-ID seen on this particular transport copy. Unlike `messageId`, this
  // is intentionally non-unique: every CC/forwarded copy is retained for forensic review.
  observedMessageId String?
  // SHA-256(normalized observed Message-ID), linked to the durable logical claim. Headerless
  // deliveries leave this NULL and are deduplicated only by their transport key.
  messageIdHash String?          @db.Char(64)
  // SHA-256 of normalized logical content. This is never a raw-MIME hash: per-hop trace
  // headers are excluded so CC copies compare as the same message.
  semanticHash String?           @db.Char(64)
  contentHash   String
  envelopeFrom  String?
  envelopeTo    String?
  subject       String           @default("")
  // Department resolved AT acceptance (snapshot) — a later queue change must not
  // re-route an already-accepted message.
  departmentId  Int?
  // Receiving queue policy as it was when the bytes became durable. NULL is a
  // legacy/unknown delivery and fails closed for EMAIL autoresponses.
  sendAutoresponder Boolean?
  // Every enabled recipient queue/policy at acceptance. It is used only to resolve a
  // ledger delivery's owner deterministically; drains never re-read mutable queues.
  routingSnapshot Json?
  // Receiving queue/department above are transport snapshots. These fields hold the immutable
  // deterministic business owner selected for this delivery/claim before ticket creation.
  routedQueue   EmailQueue?      @relation("InboundDeliveryRoutedQueue", fields: [routedQueueId], references: [id], onDelete: SetNull)
  routedQueueId Int?
  routedDepartment Department?   @relation("InboundDeliveryRoutedDepartment", fields: [routedDepartmentId], references: [id], onDelete: SetNull)
  routedDepartmentId Int?
  // Authoritative non-admin operator ACL owner. This is intentionally distinct from
  // the receiving queue snapshot and deterministic recipient route: a parser rule or
  // a threaded reply can ultimately create/update a ticket in another department.
  // TICKET follows the linked ticket's current department; if the relation is deleted,
  // its kind stays TICKET and access fails closed rather than falling back to this scalar.
  effectiveOwnerKind InboundDeliveryEffectiveOwnerKind @default(UNRESOLVED)
  effectiveOwnerDepartmentId Int?
  effectiveOwnerTicket Ticket? @relation("InboundDeliveryEffectiveOwnerTicket", fields: [effectiveOwnerTicketId], references: [id], onDelete: SetNull)
  effectiveOwnerTicketId Int?
  messageClaim InboundMessageClaim? @relation("InboundDeliveryMessageClaim", fields: [messageIdHash], references: [messageIdHash], onDelete: SetNull)
  winningMessageClaim InboundMessageClaim? @relation("InboundMessageClaimWinner")

  // Durable raw MIME so a failed/quarantined delivery can be replayed. Inline for
  // bounded messages; `rawStorageKey` is used when externalised to object storage.
  // `rawMime` is pruned (set NULL) for terminal PROCESSED/SKIPPED deliveries older than
  // the retention window; QUARANTINED and CAPTURED rows keep it (needed for replay/review). `truncated` marks
  // an IMAP fetch that hit the size ceiling — its raw bytes are incomplete (replay must
  // re-fetch the original), so it is quarantined rather than partially ticketed.
  rawMime       Bytes?
  rawStorageKey String?
  rawPrunedAt   DateTime?
  truncated     Boolean          @default(false)
  sizeBytes     Int              @default(0)

  // Lifecycle
  state         InboundDeliveryState @default(ACCEPTED)
  // Written only by the audited CAPTURED -> ACCEPTED promotion transaction. A
  // promotion-only normal canary requires this durable provenance marker so an
  // arbitrary historical ACCEPTED/RETRY row can never be selected by mistake.
  capturePromotedAt DateTime?
  attempts      Int              @default(0)
  lastError     String?
  nextAttemptAt DateTime?
  // Lease: a worker sets leaseOwner + leaseExpiresAt when it claims PROCESSING. An
  // expired lease is reclaimed by any worker, so a crash mid-processing can never strand
  // a delivery in PROCESSING forever.
  leaseOwner    String?
  leaseExpiresAt DateTime?
  ticketId      Int?
  postId        Int?

  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  processedAt   DateTime?

  @@index([state, nextAttemptAt])
  @@index([queueId, capturePromotedAt, state])
  @@index([queueId, mailboxEpoch, uidValidity, uid])
  // The raw-stage reaper verifies an externalised MIME pointer by this key while
  // holding the stage-row fence. Keep that lookup bounded so cleanup cannot delay
  // capture arming on a large terminal-delivery ledger.
  @@index([rawStorageKey])
  @@index([messageIdHash])
  @@index([observedMessageId])
  @@index([routedQueueId])
  @@index([effectiveOwnerKind, effectiveOwnerDepartmentId, state])
  @@index([effectiveOwnerTicketId])
}

/**
 * Durable fence for a large raw-MIME file between filesystem staging and its ledger row.
 * Acceptance writes COMMITTED in the same transaction as the ledger pointer. A reaper commits
 * REAPING before it touches the filesystem, so a rollback after unlink can never let a later
 * acceptance create a pointer to missing bytes.
 */
model InboundRawMimeStaging {
  storageKey     String   @id
  // The queue that still owns this uncommitted raw-MIME write. Capture arming
  // checks this durable reservation under the queue lock, so a failed cleanup
  // cannot leave bytes from a normal worker behind a newly retired queue.
  queue          EmailQueue? @relation(fields: [queueId], references: [id], onDelete: SetNull)
  queueId        Int?
  state          InboundRawMimeStagingState @default(ACTIVE)
  leaseExpiresAt DateTime
  createdAt      DateTime @default(now())

  @@index([leaseExpiresAt])
  @@index([queueId, leaseExpiresAt])
  @@index([state, leaseExpiresAt])
}

/**
 * One logical inbound RFC Message-ID. A durable row is created before ticket routing, so
 * concurrent pollers race on this primary key and exactly one winner delivery performs the
 * business action. Every transport copy remains in InboundDelivery and points back here.
 */
model InboundMessageClaim {
  // SHA-256(normalized Message-ID), fixed width for a bounded unique index.
  messageIdHash       String  @id @db.Char(64)
  normalizedMessageId String
  // NULL/version 0 is allowed only for historical rows that cannot be reconstructed safely
  // during the additive migration. New claims are always version 1 with a non-null hash;
  // a later copy against an unknown historical claim is quarantined rather than silently
  // deduplicated.
  semanticHash        String? @db.Char(64)
  semanticHashVersion Int     @default(1)

  winnerDelivery      InboundDelivery @relation("InboundMessageClaimWinner", fields: [winnerDeliveryId], references: [id], onDelete: Restrict)
  winnerDeliveryId    Int             @unique
  routedQueue         EmailQueue?     @relation("InboundMessageClaimRoutedQueue", fields: [routedQueueId], references: [id], onDelete: SetNull)
  routedQueueId       Int?
  department          Department?     @relation("InboundMessageClaimDepartment", fields: [departmentId], references: [id], onDelete: SetNull)
  departmentId        Int?
  // Frozen alongside the selected owning queue, so a winner retry cannot consult a queue that
  // was edited after acceptance to decide whether to send a customer autoresponder.
  sendAutoresponder   Boolean?
  ticket              Ticket?         @relation("InboundMessageClaimTicket", fields: [ticketId], references: [id], onDelete: SetNull)
  ticketId            Int?
  post                TicketPost?     @relation("InboundMessageClaimPost", fields: [postId], references: [id], onDelete: SetNull)
  postId              Int?

  deliveries          InboundDelivery[] @relation("InboundDeliveryMessageClaim")
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@index([routedQueueId])
  @@index([departmentId])
  @@index([ticketId])
}

/// Durable audit trail for inbound operator actions (reconcile / quarantine replay). Kept
/// separate from RbacAuditLog (staff/group RBAC) so mail-ops history is queryable on its
/// own with the queue/delivery it targeted, the acting staff, and the operator's reason.
model InboundAuditLog {
  id           Int      @id @default(autoincrement())
  actorStaffId Int? // null for system/scheduled actions
  actorEmail   String   @default("")
  action       String // e.g. mail.reconcile, mail.quarantine_replay
  queueId      Int?
  deliveryId   Int?
  reason       String?
  metadata     Json     @default("{}")
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([queueId])
}

model EmailTemplate {
  id        Int      @id @default(autoincrement())
  key       String                          // e.g. ticket_user_reply, autoresponder
  locale    String   @default("en")
  subject   String
  htmlBody  String
  textBody  String   @default("")
  updatedAt DateTime @updatedAt

  @@unique([key, locale])
}

model EmailParserRule {
  id              Int             @id @default(autoincrement())
  title           String
  ruleType        ParserRuleType  @default(PRE_PARSE)
  matchType       ParserMatchType @default(ALL)
  stopProcessing  Boolean         @default(false)
  isEnabled       Boolean         @default(true)
  sortOrder       Int             @default(0)
  criteria        Json            @default("[]")
  actions         Json            @default("[]")

  @@index([isEnabled, sortOrder])
}

// ───────────────────────────── custom fields (metadata only; values live as JSONB) ─────────────────────────────

model CustomFieldGroup {
  id           Int              @id @default(autoincrement())
  title        String
  scope        CustomFieldScope @default(TICKET)
  displayOrder Int              @default(0)
  fields       CustomField[]
}

model CustomField {
  id           Int              @id @default(autoincrement())
  group        CustomFieldGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId      Int
  // stable key used inside the owning entity's `customFields` JSONB
  fieldKey     String
  title        String
  type         CustomFieldType  @default(TEXT)
  isRequired   Boolean          @default(false)
  isEncrypted  Boolean          @default(false)
  options      Json             @default("[]")
  displayOrder Int              @default(0)

  @@unique([groupId, fieldKey])
}

// ───────────────────────────── knowledgebase ─────────────────────────────

model KbCategory {
  id           Int          @id @default(autoincrement())
  title        String
  parent       KbCategory?  @relation("KbTree", fields: [parentId], references: [id])
  parentId     Int?
  children     KbCategory[] @relation("KbTree")
  displayOrder Int          @default(0)
  isPublished  Boolean      @default(true)
  articles     KbArticle[]
}

model KbArticle {
  id            Int                @id @default(autoincrement())
  category      KbCategory?        @relation(fields: [categoryId], references: [id])
  categoryId    Int?
  title         String
  slug          String             @unique
  contents      String                              // current HTML
  contentsText  String             @default("")     // plaintext for search
  isPublished   Boolean            @default(false)
  views         Int                @default(0)
  authorStaffId Int?
  revisions     KbArticleRevision[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([categoryId])
  // C5: trigram GIN for KB article search over title + plaintext body.
  @@index([title(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([contentsText(ops: raw("gin_trgm_ops"))], type: Gin)
}

model KbArticleRevision {
  id             Int       @id @default(autoincrement())
  article        KbArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId      Int
  contents       String
  editedByStaffId Int?
  createdAt      DateTime  @default(now())

  @@index([articleId])
}

// ───────────────────────────── news ─────────────────────────────

model NewsItem {
  id            Int       @id @default(autoincrement())
  title         String
  contents      String
  isPublished   Boolean   @default(false)
  publishedAt   DateTime?
  authorStaffId Int?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ───────────────────────────── settings ─────────────────────────────

model Setting {
  id      Int    @id @default(autoincrement())
  section String
  key     String
  value   Json   @default("null")

  @@unique([section, key])
}

// ───────────────────────────── alaris integration (STUB) ─────────────────────────────

model AlarisEvent {
  id         Int      @id @default(autoincrement())
  externalId String   @unique
  severity   String   @default("info")
  payload    Json     @default("{}")
  ticket     Ticket?  @relation(fields: [ticketId], references: [id])
  ticketId   Int?     @unique
  receivedAt DateTime @default(now())
}

// ───────────────────────────── troubleshooter (branching guides) ─────────────────────────────

model TroubleshooterCategory {
  id           Int                       @id @default(autoincrement())
  title        String
  parent       TroubleshooterCategory?   @relation("TsTree", fields: [parentId], references: [id])
  parentId     Int?
  children     TroubleshooterCategory[]  @relation("TsTree")
  displayOrder Int                       @default(0)
  isPublished  Boolean                   @default(true)
  steps        TroubleshooterStep[]
}

model TroubleshooterStep {
  id           Int                     @id @default(autoincrement())
  category     TroubleshooterCategory  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId   Int
  title        String
  contents     String
  displayOrder Int                     @default(0)
  // branching: outgoing links to next steps
  linksFrom    TroubleshooterStepLink[] @relation("TsFrom")
  linksTo      TroubleshooterStepLink[] @relation("TsTo")
  createdAt    DateTime                @default(now())

  @@index([categoryId])
}

model TroubleshooterStepLink {
  id       Int                @id @default(autoincrement())
  from     TroubleshooterStep @relation("TsFrom", fields: [fromId], references: [id], onDelete: Cascade)
  fromId   Int
  to       TroubleshooterStep @relation("TsTo", fields: [toId], references: [id], onDelete: Cascade)
  toId     Int
  label    String             @default("")

  @@unique([fromId, toId])
}

// ───────────────────────────── reports ─────────────────────────────

enum ReportKind {
  TABULAR
  SUMMARY
  MATRIX
}

model Report {
  id         Int              @id @default(autoincrement())
  title      String
  kind       ReportKind       @default(SUMMARY)
  // declarative definition: { source, filters, groupBy, aggregates, orderBy, limit }
  definition Json             @default("{}")
  // Every semantic edit advances this fence. A scanner that compiled an older
  // definition/title must not create a ReportRun or SMTP command after the edit.
  configGeneration Int        @default(0)
  schedules  ReportSchedule[]
  runs       ReportRun[]
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
}

model ReportSchedule {
  id          Int       @id @default(autoincrement())
  report      Report    @relation(fields: [reportId], references: [id], onDelete: Cascade)
  reportId    Int
  // Scheduled execution has no request principal.  It always runs with this
  // owner's current RBAC + department scope; legacy ownerless schedules are
  // disabled by the ownership migration rather than executed globally.
  ownerStaff  Staff?    @relation("ReportScheduleOwner", fields: [ownerStaffId], references: [id], onDelete: SetNull)
  ownerStaffId Int?
  cron        String
  recipients  Json      @default("[]")
  isEnabled   Boolean   @default(true)
  format      String    @default("json")
  // Changes to recipients, owner, cron, format or enabled state invalidate an
  // in-flight schedule scan before it can persist a report/outbox command.
  configGeneration Int @default(0)
  lastRunAt   DateTime?
  nextRunAt   DateTime?

  @@index([reportId])
  @@index([ownerStaffId])
  // Load: the schedule scanner polls due+enabled schedules every 5 min.
  @@index([isEnabled, nextRunAt])
}

model ReportRun {
  id          Int      @id @default(autoincrement())
  report      Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  reportId    Int
  triggeredBy String   @default("manual")   // "manual" | "schedule"
  staffId     Int?
  rowCount    Int      @default(0)
  durationMs  Int      @default(0)
  error       String?
  resultKey   String?  // storage key for large results (future)
  outboundEmail OutboundEmail? @relation("ReportRunOutboundEmail")
  createdAt   DateTime @default(now())

  @@index([reportId])
}

/**
 * Immutable snapshot of customer `send_email` workflow actions selected in the same ticket
 * transaction as the event that triggered them. Redis/EventEmitter can wake this work, but
 * never owns its correctness: the processor recovers PENDING/RETRY rows from PostgreSQL.
 */
model WorkflowEmailEvent {
  id             String                  @id @default(cuid())
  ticket         Ticket                  @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  ticketId       Int
  eventType      String
  // Immutable business mutation identity (post/audit/split), not a generated process id.
  // This is the event-level retry/replay fence; action-level keys derive from it.
  sourceKey      String                  @unique
  // Validated action snapshots: workflow identity/version, index, recipient, subject, body.
  actions        Json
  state          WorkflowEmailEventState @default(PENDING)
  attempts       Int                     @default(0)
  nextAttemptAt  DateTime?
  leaseOwner     String?
  leaseExpiresAt DateTime?
  leaseVersion   Int                     @default(0)
  lastError      String?
  processedAt    DateTime?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  @@index([ticketId])
  @@index([state, nextAttemptAt])
  @@index([leaseExpiresAt])
}

// ───────────────────────────── agent productivity (P3) ─────────────────────────────

/** Time logged by a staff member against a ticket (minutes). */
model TimeEntry {
  id        Int      @id @default(autoincrement())
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  ticketId  Int
  // Restrict: staff are soft-disabled (never hard-deleted), so attribution is preserved.
  staff     Staff    @relation(fields: [staffId], references: [id], onDelete: Restrict)
  staffId   Int
  minutes   Int
  note      String?
  spentAt   DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([ticketId])
  @@index([staffId])
}

/** A scheduled follow-up reminder on a ticket. */
model FollowUp {
  id          Int       @id @default(autoincrement())
  ticket      Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  ticketId    Int
  staff       Staff     @relation(fields: [staffId], references: [id], onDelete: Restrict)
  staffId     Int
  dueAt       DateTime
  note        String?
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([ticketId])
  @@index([dueAt])
  @@index([staffId])
}

/** A named, reusable set of ticket-list filters saved by a staff member. */
model SavedView {
  id        Int      @id @default(autoincrement())
  staff     Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  staffId   Int
  name      String
  filters   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([staffId, name])
  @@index([staffId])
}
