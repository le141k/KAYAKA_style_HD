// 23 Telecom Help Desk — data model
// Modern, normalized rewrite of the Kayako Classic `kayako_fusion` schema.
// Key modernizations vs. Kayako:
//   * real foreign keys & referential integrity (Kayako had none)
//   * DateTime instead of unix-int columns
//   * custom fields as JSONB (`customFields`) instead of the EAV value table
//   * attachments referenced by storage key (disk/object store), not chunked BLOBs
//   * denormalized `*title` mirror columns dropped (joined live instead)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ───────────────────────────── enums ─────────────────────────────

enum DepartmentType {
  PUBLIC
  PRIVATE
}

enum UserGroupType {
  GUEST
  REGISTERED
}

// 23 Telecom is a broker in the middle: customers (CLIENT) email in, 23T (INTERNAL)
// works the issue and contacts carriers (SUPPLIER). Used to classify orgs on import.
enum OrgType {
  CLIENT
  SUPPLIER
  INTERNAL
}

enum ActorType {
  STAFF
  USER
  SYSTEM
}

enum CreationMode {
  WEB
  EMAIL
  API
  STAFF
  ALARIS
}

enum CustomFieldScope {
  TICKET
  USER
  STAFF
  ORGANIZATION
}

enum CustomFieldType {
  TEXT
  TEXTAREA
  PASSWORD
  CHECKBOX
  RADIO
  SELECT
  MULTISELECT
  DATE
  NUMBER
  FILE
  CUSTOM
}

enum SlaTargetType {
  FIRST_RESPONSE
  RESOLUTION
}

enum EmailQueueType {
  IMAP
  POP3
  PIPE
}

// Inbound delivery ledger — durable record of every accepted inbound message so
// processing failures never lose mail (raw MIME is replayable) and re-delivery is
// idempotent by a unique transport key.
enum InboundTransport {
  IMAP
  PIPE
}

enum InboundDeliveryState {
  ACCEPTED // durably recorded (raw MIME stored); not yet processed
  PROCESSING // claimed by a drain worker
  PROCESSED // business op committed (ticket/post created or threaded)
  RETRY // transient failure; retried with backoff, never discarded
  QUARANTINED // permanent failure / attempts exhausted; needs operator, raw MIME retained
  SKIPPED // intentionally not ticketed (loop/bounce/parser-ignore/duplicate)
}

// Per-queue IMAP sync health. NEEDS_RECONCILIATION halts polling (fail-closed) after a
// UIDVALIDITY change so an operator explicitly chooses FROM_NOW or a bounded BACKFILL.
// BOOTSTRAPPING is transient: an operator reconcile holds the queue here while it captures
// UIDVALIDITY/UIDNEXT under the IMAP mailbox lock.  The same request durably commits that
// exact baseline before it returns OK, so health never reports a cursor before it exists.
enum EmailQueueSyncState {
  OK
  BOOTSTRAPPING
  NEEDS_RECONCILIATION
}

// Why an IMAP queue is halted/reconciling.  This is deliberately durable and
// server-side: the UI must never infer that a dangerous resume is safe from a
// free-form lastError string.
enum EmailQueueReconcileCause {
  LEGACY_MIGRATION
  UIDVALIDITY_CHANGED
  MAILBOX_IDENTITY_CHANGED
  MANUAL_FORCE
  TRANSPORT_COLLISION
  UNKNOWN
}

enum FlagType {
  NONE
  PURPLE
  ORANGE
  GREEN
  YELLOW
  RED
  BLUE
}

enum RecipientRole {
  CC
  BCC
}

enum ParserRuleType {
  PRE_PARSE
  POST_PARSE
}

enum ParserMatchType {
  ALL
  ANY
}

// ───────────────────────────── staff / RBAC ─────────────────────────────

model StaffGroup {
  id          Int      @id @default(autoincrement())
  title       String
  isAdmin     Boolean  @default(false)
  // RBAC: list of permission keys (see apps/api/src/auth/permissions.ts catalog)
  permissions String[] @default([])
  staff       Staff[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Staff {
  id              Int       @id @default(autoincrement())
  email           String    @unique
  username        String    @unique
  firstName       String
  lastName        String
  passwordHash    String
  designation     String    @default("")
  signature       String    @default("")
  mobileNumber    String    @default("")
  timezone        String    @default("UTC")
  isEnabled       Boolean   @default(true)
  // Bumped on every security-relevant change (password/disable/group/permission).
  // Embedded in each access token as the `av` claim; the JWT guard rejects any token
  // whose `av` no longer matches, so revocation is immediate (GOAL_PUBLIC_SECURITY S3).
  authVersion     Int       @default(0)
  staffGroup      StaffGroup @relation(fields: [staffGroupId], references: [id])
  staffGroupId    Int
  // departments this agent can act in (empty = all, governed by group)
  departments     DepartmentStaff[]
  ownedTickets    Ticket[]  @relation("TicketOwner")
  posts           TicketPost[]
  notes           TicketNote[]
  auditLogs       TicketAuditLog[]
  refreshTokens   RefreshToken[]
  watching        TicketWatcher[]
  timeEntries     TimeEntry[]
  followUps       FollowUp[]
  savedViews      SavedView[]
  lastLoginAt     DateTime?
  // D2 — per-account brute-force lockout (complements the per-IP rate limiter).
  failedLoginAttempts Int    @default(0)
  lockedUntil     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([staffGroupId])
  // C5: trigram GIN for ILIKE staff name search.
  @@index([firstName(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([lastName(ops: raw("gin_trgm_ops"))], type: Gin)
}

model RefreshToken {
  id        String   @id @default(uuid())
  staff     Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  staffId   Int
  // Opaque rotation identifiers (S3-3): `jti` is the refresh JWT's id, looked up
  // directly (no Argon2 scan); `familyId` groups a rotation chain so a detected replay
  // can revoke the whole family.
  jti       String   @unique
  familyId  String
  // The staff authVersion this token was issued under. A refresh whose row.authVersion
  // no longer matches the staff record is rejected — so logout-all / password / group
  // changes can't be outrun by a concurrently-rotating session (S3, race fix).
  authVersion Int    @default(0)
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@index([staffId])
  // Load: bound the refresh-rotation scan + support expired-token cleanup.
  @@index([staffId, revokedAt])
  @@index([staffId, expiresAt])
  @@index([familyId])
}

model PasswordReset {
  id          Int       @id @default(autoincrement())
  staffId     Int
  // Security-state stamp at issuance; reset requires an exact Staff.authVersion match.
  authVersion Int       @default(-1)
  tokenHash   String    @unique   // sha256 hex of the raw token
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([staffId])
  @@index([expiresAt])
  @@index([staffId, usedAt])
  // A raw migration adds a partial UNIQUE(staffId) WHERE usedAt IS NULL;
  // Prisma schema syntax cannot represent partial indexes.
}

// Append-only audit trail for RBAC / staff-account changes: who did what to which
// staff member or group. `actorStaffId` is a plain int (no FK) so rows survive even
// if the actor is later removed; `metadata` carries a small JSON diff/summary.
model RbacAuditLog {
  id           Int      @id @default(autoincrement())
  actorStaffId Int?     // null for system/bootstrap actions
  actorEmail   String   @default("")
  action       String   // e.g. staff.create, staff.role_change, staff.password_reset, staff.disable, group.update
  targetType   String   // 'staff' | 'group'
  targetId     Int?
  targetLabel  String   @default("")
  metadata     Json     @default("{}")
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([actorStaffId])
  @@index([targetType, targetId])
}

// ─── Verified client (customer) auth — GOAL_PUBLIC_SECURITY S2 ───
// Replaces "knowing an email" with a verified, revocable session bound to a stable
// User.id. Only SHA-256 hashes of cryptographically-random tokens are stored; the raw
// token is never persisted. `email` is an audit snapshot, NEVER the authorization key.

model ClientLoginToken {
  id                String    @id @default(uuid())
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId            Int
  // Version of the client identity at issuance. Verification requires this to equal
  // User.clientAuthVersion, so disable/re-enable and email changes burn old links.
  clientAuthVersion Int       @default(-1)
  tokenHash         String    @unique // sha256 hex of the single-use raw login token
  email             String // normalized-email snapshot (audit only)
  expiresAt         DateTime
  usedAt            DateTime?
  createdAt         DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model ClientSession {
  id                String    @id @default(uuid())
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId            Int
  // Must match User.clientAuthVersion on every resolution.
  clientAuthVersion Int       @default(-1)
  tokenHash         String    @unique // sha256 hex of the raw session cookie value
  email             String // normalized-email snapshot (audit only)
  expiresAt         DateTime
  revokedAt         DateTime?
  createdAt         DateTime  @default(now())
  lastSeenAt        DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// ───────────────────────────── customers / orgs ─────────────────────────────

model UserGroup {
  id        Int           @id @default(autoincrement())
  title     String
  type      UserGroupType @default(REGISTERED)
  isMaster  Boolean       @default(false)
  users     User[]
  createdAt DateTime      @default(now())
}

model Organization {
  id          Int      @id @default(autoincrement())
  // Kayako source id — set by the importer for idempotent upserts/FK resolution.
  kayakoId    Int?     @unique
  orgType     OrgType  @default(CLIENT)
  name        String
  address     String   @default("")
  city        String   @default("")
  state       String   @default("")
  postalCode  String   @default("")
  country     String   @default("")
  phone       String   @default("")
  website     String   @default("")
  slaPlan     SlaPlan? @relation(fields: [slaPlanId], references: [id])
  slaPlanId   Int?
  users       User[]
  customFields Json    @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // C5: trigram GIN for ILIKE org name search (OrganizationsService.list).
  @@index([name(ops: raw("gin_trgm_ops"))], type: Gin)
}

model User {
  id             Int           @id @default(autoincrement())
  kayakoId       Int?          @unique
  fullName       String
  phone          String        @default("")
  designation    String        @default("")
  // nullable: many customers are created from inbound email without a password
  passwordHash      String?
  isEnabled         Boolean       @default(true)
  // Bumped whenever the verified client identity changes (enable state or email set).
  // Login tokens and sessions are stamped with this value for durable revocation.
  clientAuthVersion Int           @default(0)
  isValidated       Boolean       @default(false)
  timezone       String        @default("UTC")
  userGroup      UserGroup?    @relation(fields: [userGroupId], references: [id])
  userGroupId    Int?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  organizationId Int?
  emails         UserEmail[]
  tickets        Ticket[]
  loginTokens    ClientLoginToken[]
  sessions       ClientSession[]
  posts          TicketPost[]
  geoip          Json?
  customFields   Json          @default("{}")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([organizationId])
  // C5: trigram GIN for ILIKE user search (UsersService.list). Needs pg_trgm (enabled).
  @@index([fullName(ops: raw("gin_trgm_ops"))], type: Gin)
}

model UserEmail {
  id        Int     @id @default(autoincrement())
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  email     String  @unique
  isPrimary Boolean @default(false)

  @@index([userId])
}

// ───────────────────────────── departments ─────────────────────────────

model Department {
  id           Int            @id @default(autoincrement())
  title        String
  type         DepartmentType @default(PUBLIC)
  app          String         @default("tickets")
  isDefault    Boolean        @default(false)
  displayOrder Int            @default(0)
  parent       Department?    @relation("DepartmentTree", fields: [parentId], references: [id])
  parentId     Int?
  children     Department[]   @relation("DepartmentTree")
  tickets      Ticket[]
  staff        DepartmentStaff[]
  emailQueues  EmailQueue[]
  createdAt    DateTime       @default(now())
}

model DepartmentStaff {
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  departmentId Int
  staff        Staff      @relation(fields: [staffId], references: [id], onDelete: Cascade)
  staffId      Int

  @@id([departmentId, staffId])
}

// ───────────────────────────── ticket reference data ─────────────────────────────

model TicketStatus {
  id            Int      @id @default(autoincrement())
  title         String
  displayOrder  Int      @default(0)
  markAsResolved Boolean @default(false)
  color         String   @default("")
  bgColor       String   @default("")
  displayIcon   String   @default("")
  triggersSurvey Boolean @default(false)
  isDefault     Boolean  @default(false)
  tickets       Ticket[]
}

model TicketPriority {
  id           Int      @id @default(autoincrement())
  title        String
  displayOrder Int      @default(0)
  color        String   @default("")
  bgColor      String   @default("")
  tickets      Ticket[]
}

model TicketType {
  id           Int      @id @default(autoincrement())
  title        String
  displayOrder Int      @default(0)
  displayIcon  String   @default("")
  tickets      Ticket[]
}

// ───────────────────────────── tickets ─────────────────────────────

model Ticket {
  id              Int            @id @default(autoincrement())
  kayakoId        Int?           @unique
  mask            String         @unique          // human ID, e.g. TT-000123
  subject         String

  department      Department     @relation(fields: [departmentId], references: [id])
  departmentId    Int
  status          TicketStatus   @relation(fields: [statusId], references: [id])
  statusId        Int
  priority        TicketPriority @relation(fields: [priorityId], references: [id])
  priorityId      Int
  type            TicketType?    @relation(fields: [typeId], references: [id])
  typeId          Int?

  // requester (registered user optional; raw email always captured)
  user            User?          @relation(fields: [userId], references: [id])
  userId          Int?
  requesterName   String         @default("")
  requesterEmail  String         @default("")

  owner           Staff?         @relation("TicketOwner", fields: [ownerStaffId], references: [id])
  ownerStaffId    Int?

  slaPlan         SlaPlan?       @relation(fields: [slaPlanId], references: [id])
  slaPlanId       Int?
  dueAt           DateTime?
  resolutionDueAt DateTime?
  firstResponseAt DateTime?
  resolvedAt      DateTime?
  reopenedAt      DateTime?

  creationMode    CreationMode   @default(WEB)
  creator         ActorType      @default(USER)
  flagType        FlagType       @default(NONE)

  totalReplies    Int            @default(0)
  hasAttachments  Boolean        @default(false)
  hasNotes        Boolean        @default(false)
  isResolved      Boolean        @default(false)
  isEscalated     Boolean        @default(false)
  escalationLevel Int            @default(0)
  wasReopened     Boolean        @default(false)
  isPhoneCall     Boolean        @default(false)
  ipAddress       String         @default("0.0.0.0")

  // threading
  messageId       String?        @default("")

  // merge: when merged, points to surviving ticket
  mergedInto      Ticket?        @relation("TicketMerge", fields: [mergedIntoId], references: [id])
  mergedIntoId    Int?
  mergedFrom      Ticket[]       @relation("TicketMerge")

  customFields    Json           @default("{}")

  posts           TicketPost[]
  notes           TicketNote[]
  attachments     Attachment[]
  watchers        TicketWatcher[]
  tags            TicketTag[]
  auditLogs       TicketAuditLog[]
  linksFrom       TicketLink[]   @relation("LinkSource")
  linksTo         TicketLink[]   @relation("LinkTarget")
  alarisEvent     AlarisEvent?
  recipients      TicketRecipient[]
  timeEntries     TimeEntry[]
  followUps       FollowUp[]

  lastReplyAt     DateTime?
  lastActivityAt  DateTime       @default(now())
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([statusId])
  @@index([departmentId])
  @@index([ownerStaffId])
  @@index([userId])
  @@index([lastActivityAt])
  @@index([createdAt])
  // Load: frequently filtered/sorted columns (list filters, SLA breach scan, reports)
  @@index([priorityId])
  @@index([typeId])
  @@index([isResolved])
  @@index([mergedIntoId])
  @@index([dueAt])
  @@index([resolutionDueAt])
  // Composite for the 60s SLA breach scan (isResolved=false, isEscalated=false, mergedIntoId=null)
  @@index([isResolved, isEscalated, mergedIntoId])
  // Trigram GIN indexes so the list `search` (ILIKE '%term%') uses an index
  // instead of a sequential scan. Requires the pg_trgm extension (prior migration).
  @@index([subject(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([requesterEmail(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([requesterName(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([mask(ops: raw("gin_trgm_ops"))], type: Gin)
}

model TicketPost {
  id           Int        @id @default(autoincrement())
  ticket       Ticket     @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  ticketId     Int
  authorType   ActorType  @default(USER)
  staff        Staff?     @relation(fields: [staffId], references: [id])
  staffId      Int?
  user         User?      @relation(fields: [userId], references: [id])
  userId       Int?
  fullName     String     @default("")
  email        String     @default("")
  subject      String     @default("")
  contents     String     // body (HTML or plaintext per isHtml)
  isHtml       Boolean    @default(true)
  isEmailed    Boolean    @default(false)
  isThirdParty Boolean    @default(false)
  creationMode CreationMode @default(WEB)
  messageId    String?    @unique // RFC Message-ID for threading/idempotency; absent = NULL
  ipAddress    String     @default("0.0.0.0")
  attachments  Attachment[]
  editedAt     DateTime?
  editedByStaffId Int?
  createdAt    DateTime   @default(now())

  @@index([ticketId])
}

model TicketNote {
  id          Int          @id @default(autoincrement())
  ticket      Ticket       @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  ticketId    Int
  staff       Staff?       @relation(fields: [staffId], references: [id])
  staffId     Int?
  contents    String
  attachments Attachment[]
  createdAt   DateTime     @default(now())

  @@index([ticketId])
}

model Attachment {
  id         Int         @id @default(autoincrement())
  ticket     Ticket?     @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  ticketId   Int?
  post       TicketPost? @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId     Int?
  // U1: note attachments — link to the note that owns this attachment (null = post/ticket-level)
  note       TicketNote? @relation(fields: [noteId], references: [id], onDelete: Cascade)
  noteId     Int?
  fileName   String
  mimeType   String      @default("application/octet-stream")
  size       Int         @default(0)
  sha1       String      @default("")
  storageKey String                       // path/key in object store or disk
  // Per-upload secret for anonymous orphan uploads. The public submit/reply must
  // echo it back to adopt these orphans (prevents cross-submitter IDOR). Cleared
  // once the rows are linked to a post.
  claimToken String?
  createdAt  DateTime    @default(now())

  @@index([ticketId])
  @@index([postId])
  @@index([noteId])
  @@index([claimToken])
}

model TicketWatcher {
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  ticketId Int
  staff    Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)
  staffId  Int

  @@id([ticketId, staffId])
}

model TicketTag {
  id      Int      @id @default(autoincrement())
  name    String   @unique
  tickets Ticket[]
}

model TicketAuditLog {
  id        Int       @id @default(autoincrement())
  ticket    Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  ticketId  Int
  staff     Staff?    @relation(fields: [staffId], references: [id])
  staffId   Int?
  actorType ActorType @default(STAFF)
  action    String                       // e.g. STATUS_CHANGE, ASSIGN, REPLY, MERGE
  field     String?
  oldValue  String?
  newValue  String?
  createdAt DateTime  @default(now())

  @@index([ticketId])
  @@index([createdAt])
}

model TicketLink {
  id        Int    @id @default(autoincrement())
  source    Ticket @relation("LinkSource", fields: [sourceId], references: [id], onDelete: Cascade)
  sourceId  Int
  target    Ticket @relation("LinkTarget", fields: [targetId], references: [id], onDelete: Cascade)
  targetId  Int
  linkType  String @default("related")

  @@unique([sourceId, targetId])
}

model TicketRecipient {
  id       Int           @id @default(autoincrement())
  ticket   Ticket        @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  ticketId Int
  email    String
  role     RecipientRole
  addedAt  DateTime      @default(now())

  @@unique([ticketId, email])
  @@index([ticketId])
}

// ───────────────────────────── SLA / escalation ─────────────────────────────

model SlaSchedule {
  id        Int          @id @default(autoincrement())
  title     String
  // weekly operational hours: { mon: [["09:00","18:00"]], ... }
  workHours Json         @default("{}")
  holidays  SlaHoliday[]
  plans     SlaPlan[]
  createdAt DateTime     @default(now())
}

model SlaHoliday {
  id         Int         @id @default(autoincrement())
  schedule   SlaSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  scheduleId Int
  title      String
  date       DateTime

  @@index([scheduleId])
}

model SlaPlan {
  id                   Int             @id @default(autoincrement())
  title                String
  isEnabled            Boolean         @default(true)
  // criteria for auto-applying the plan (JSON rule set)
  criteria             Json            @default("[]")
  firstResponseSeconds Int?
  resolutionSeconds    Int?
  schedule             SlaSchedule?    @relation(fields: [scheduleId], references: [id])
  scheduleId           Int?
  escalationRules      EscalationRule[]
  tickets              Ticket[]
  organizations        Organization[]
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
}

model EscalationRule {
  id              Int           @id @default(autoincrement())
  slaPlan         SlaPlan       @relation(fields: [slaPlanId], references: [id], onDelete: Cascade)
  slaPlanId       Int
  name            String
  targetType      SlaTargetType @default(FIRST_RESPONSE)
  thresholdSeconds Int          @default(0)
  // actions to run on breach (assign, notify, change priority…)
  actions         Json          @default("[]")
  isEnabled       Boolean       @default(true)

  @@index([slaPlanId])
}

// ───────────────────────────── workflows / macros ─────────────────────────────

model MacroCategory {
  id      Int     @id @default(autoincrement())
  title   String
  parent  MacroCategory? @relation("MacroTree", fields: [parentId], references: [id])
  parentId Int?
  children MacroCategory[] @relation("MacroTree")
  macros  Macro[]
}

model Macro {
  id         Int            @id @default(autoincrement())
  kayakoId   Int?           @unique
  category   MacroCategory? @relation(fields: [categoryId], references: [id])
  categoryId Int?
  title      String
  subject    String         @default("")
  replyText  String         @default("")
  isHtml     Boolean        @default(false)
  // bulk actions applied with the macro
  actions    Json           @default("[]")
  // shared = visible to all agents; false = owner-only (UI toggle)
  isShared   Boolean        @default(true)
  createdAt  DateTime       @default(now())
}

model Workflow {
  id        Int      @id @default(autoincrement())
  title     String
  criteria  Json     @default("[]")   // condition set
  actions   Json     @default("[]")   // actions to apply
  isEnabled Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Load: every ticket event queries enabled workflows ordered by sortOrder.
  @@index([isEnabled, sortOrder])
}

// ───────────────────────────── mail ─────────────────────────────

model EmailQueue {
  id             Int            @id @default(autoincrement())
  type           EmailQueueType @default(IMAP)
  emailAddress   String         @unique
  host           String         @default("")
  port           Int            @default(993)
  username       String         @default("")
  passwordEnc    String         @default("")   // encrypted at rest
  useTls         Boolean        @default(true)
  department     Department?    @relation(fields: [departmentId], references: [id])
  departmentId   Int?
  signature      String         @default("")
  // Kayako `ticketautoresponder`: only send the autoresponder for EMAIL tickets
  // when the receiving queue opts in (noc@/rates@ are OFF in the source system).
  sendAutoresponder Boolean      @default(false)
  isEnabled      Boolean        @default(false)
  createdAt      DateTime       @default(now())

  // Durable IMAP poll cursor (replaces the legacy Setting `imap/lastSeenUid:<id>`).
  // `uidValidity` NULL means the queue has never been bootstrapped → the poller sets a
  // synchronous baseline before its first fetch (no historical import). A UIDVALIDITY
  // change flips `syncState` to NEEDS_RECONCILIATION and halts polling (fail-closed).
  lastSeenUid    BigInt              @default(0)
  uidValidity    BigInt?
  syncState      EmailQueueSyncState @default(OK)
  lastError      String?
  // Bumped on every reconcile/rebootstrap. The cursor CAS is gated on this so a stale
  // poller (finishing after a reconcile) can't write a cursor from the old UID space.
  cursorGeneration Int               @default(0)
  // Bumped whenever the IMAP mailbox identity changes (including IMAP <-> non-IMAP
  // transitions). UIDVALIDITY/UID pairs are only meaningful within this epoch.
  mailboxEpoch     Int               @default(1)
  // A halted/reconciling mailbox carries a durable, typed reason. It determines the
  // server-side allowed reconcile modes; never derive safety from lastError text.
  reconcileCause       EmailQueueReconcileCause?
  reconcileRequestedAt DateTime?
  // Per-queue re-bootstrap intent set by an explicit operator reconcile (overrides the
  // global TELECOM_HD_IMAP_BOOTSTRAP_POLICY for THIS queue's next bootstrap). NULL = use
  // the global config. Only consulted while `uidValidity IS NULL` (never bootstrapped).
  bootstrapPolicy       EmailQueueBootstrapPolicy?
  bootstrapBackfillLimit Int?

  // Operator liveness signal (advisory; not part of any CAS). The supervisor stamps
  // lastConnectedAt on a successful IMAP connect, the poller lastPollAt each cycle, and
  // the accept path lastAcceptedAt when a message is durably recorded.
  lastConnectedAt DateTime?
  lastPollAt      DateTime?
  lastAcceptedAt  DateTime?

  inboundDeliveries InboundDelivery[]
}

/** Per-queue bootstrap intent chosen by an operator reconcile (see EmailQueue). */
enum EmailQueueBootstrapPolicy {
  FROM_NOW
  BACKFILL
}

model InboundDelivery {
  id            Int              @id @default(autoincrement())
  transport     InboundTransport
  queue         EmailQueue?      @relation(fields: [queueId], references: [id])
  queueId       Int?

  // Canonical idempotency key — the atomic claim. Unique across all deliveries:
  //   IMAP: `imap:<queueId>:<mailboxEpoch>:<uidValidity>:<uid>`
  //   PIPE: `pipe:<queueId|->:<externalId or sha256:hash>`
  transportKey  String           @unique

  // IMAP transport identity (also stored structured for admin/observability). IMAP UIDs
  // are unsigned 32-bit, so BigInt (not signed 32-bit INTEGER) to avoid overflow.
  // `mailboxEpoch` snapshots the queue's identity generation at acceptance, preventing a
  // new mailbox reusing UIDVALIDITY/UID from colliding with an older mailbox's delivery.
  mailboxEpoch  Int?
  uidValidity   BigInt?
  uid           BigInt?
  // PIPE/MTA transport identity (webhook idempotency id / MTA delivery id)
  externalId    String?

  // Message identity. UNIQUE (Postgres allows multiple NULLs) = the atomic logical-message
  // claim: at most one delivery may own a given effective Message-ID (race-safe dedup).
  messageId     String?          @unique
  contentHash   String
  envelopeFrom  String?
  envelopeTo    String?
  subject       String           @default("")
  // Department resolved AT acceptance (snapshot) — a later queue change must not
  // re-route an already-accepted message.
  departmentId  Int?

  // Durable raw MIME so a failed/quarantined delivery can be replayed. Inline for
  // bounded messages; `rawStorageKey` is used when externalised to object storage.
  // `rawMime` is pruned (set NULL) for terminal PROCESSED/SKIPPED deliveries older than
  // the retention window; QUARANTINED rows keep it (needed for replay). `truncated` marks
  // an IMAP fetch that hit the size ceiling — its raw bytes are incomplete (replay must
  // re-fetch the original), so it is quarantined rather than partially ticketed.
  rawMime       Bytes?
  rawStorageKey String?
  rawPrunedAt   DateTime?
  truncated     Boolean          @default(false)
  sizeBytes     Int              @default(0)

  // Lifecycle
  state         InboundDeliveryState @default(ACCEPTED)
  attempts      Int              @default(0)
  lastError     String?
  nextAttemptAt DateTime?
  // Lease: a worker sets leaseOwner + leaseExpiresAt when it claims PROCESSING. An
  // expired lease is reclaimed by any worker, so a crash mid-processing can never strand
  // a delivery in PROCESSING forever.
  leaseOwner    String?
  leaseExpiresAt DateTime?
  ticketId      Int?
  postId        Int?

  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  processedAt   DateTime?

  @@index([state, nextAttemptAt])
  @@index([queueId, mailboxEpoch, uidValidity, uid])
}

/// Durable audit trail for inbound operator actions (reconcile / quarantine replay). Kept
/// separate from RbacAuditLog (staff/group RBAC) so mail-ops history is queryable on its
/// own with the queue/delivery it targeted, the acting staff, and the operator's reason.
model InboundAuditLog {
  id           Int      @id @default(autoincrement())
  actorStaffId Int? // null for system/scheduled actions
  actorEmail   String   @default("")
  action       String // e.g. mail.reconcile, mail.quarantine_replay
  queueId      Int?
  deliveryId   Int?
  reason       String?
  metadata     Json     @default("{}")
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([queueId])
}

model EmailTemplate {
  id        Int      @id @default(autoincrement())
  key       String                          // e.g. ticket_user_reply, autoresponder
  locale    String   @default("en")
  subject   String
  htmlBody  String
  textBody  String   @default("")
  updatedAt DateTime @updatedAt

  @@unique([key, locale])
}

model EmailParserRule {
  id              Int             @id @default(autoincrement())
  title           String
  ruleType        ParserRuleType  @default(PRE_PARSE)
  matchType       ParserMatchType @default(ALL)
  stopProcessing  Boolean         @default(false)
  isEnabled       Boolean         @default(true)
  sortOrder       Int             @default(0)
  criteria        Json            @default("[]")
  actions         Json            @default("[]")

  @@index([isEnabled, sortOrder])
}

// ───────────────────────────── custom fields (metadata only; values live as JSONB) ─────────────────────────────

model CustomFieldGroup {
  id           Int              @id @default(autoincrement())
  title        String
  scope        CustomFieldScope @default(TICKET)
  displayOrder Int              @default(0)
  fields       CustomField[]
}

model CustomField {
  id           Int              @id @default(autoincrement())
  group        CustomFieldGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId      Int
  // stable key used inside the owning entity's `customFields` JSONB
  fieldKey     String
  title        String
  type         CustomFieldType  @default(TEXT)
  isRequired   Boolean          @default(false)
  isEncrypted  Boolean          @default(false)
  options      Json             @default("[]")
  displayOrder Int              @default(0)

  @@unique([groupId, fieldKey])
}

// ───────────────────────────── knowledgebase ─────────────────────────────

model KbCategory {
  id           Int          @id @default(autoincrement())
  title        String
  parent       KbCategory?  @relation("KbTree", fields: [parentId], references: [id])
  parentId     Int?
  children     KbCategory[] @relation("KbTree")
  displayOrder Int          @default(0)
  isPublished  Boolean      @default(true)
  articles     KbArticle[]
}

model KbArticle {
  id            Int                @id @default(autoincrement())
  category      KbCategory?        @relation(fields: [categoryId], references: [id])
  categoryId    Int?
  title         String
  slug          String             @unique
  contents      String                              // current HTML
  contentsText  String             @default("")     // plaintext for search
  isPublished   Boolean            @default(false)
  views         Int                @default(0)
  authorStaffId Int?
  revisions     KbArticleRevision[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([categoryId])
  // C5: trigram GIN for KB article search over title + plaintext body.
  @@index([title(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([contentsText(ops: raw("gin_trgm_ops"))], type: Gin)
}

model KbArticleRevision {
  id             Int       @id @default(autoincrement())
  article        KbArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId      Int
  contents       String
  editedByStaffId Int?
  createdAt      DateTime  @default(now())

  @@index([articleId])
}

// ───────────────────────────── news ─────────────────────────────

model NewsItem {
  id            Int       @id @default(autoincrement())
  title         String
  contents      String
  isPublished   Boolean   @default(false)
  publishedAt   DateTime?
  authorStaffId Int?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ───────────────────────────── settings ─────────────────────────────

model Setting {
  id      Int    @id @default(autoincrement())
  section String
  key     String
  value   Json   @default("null")

  @@unique([section, key])
}

// ───────────────────────────── alaris integration (STUB) ─────────────────────────────

model AlarisEvent {
  id         Int      @id @default(autoincrement())
  externalId String   @unique
  severity   String   @default("info")
  payload    Json     @default("{}")
  ticket     Ticket?  @relation(fields: [ticketId], references: [id])
  ticketId   Int?     @unique
  receivedAt DateTime @default(now())
}

// ───────────────────────────── troubleshooter (branching guides) ─────────────────────────────

model TroubleshooterCategory {
  id           Int                       @id @default(autoincrement())
  title        String
  parent       TroubleshooterCategory?   @relation("TsTree", fields: [parentId], references: [id])
  parentId     Int?
  children     TroubleshooterCategory[]  @relation("TsTree")
  displayOrder Int                       @default(0)
  isPublished  Boolean                   @default(true)
  steps        TroubleshooterStep[]
}

model TroubleshooterStep {
  id           Int                     @id @default(autoincrement())
  category     TroubleshooterCategory  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId   Int
  title        String
  contents     String
  displayOrder Int                     @default(0)
  // branching: outgoing links to next steps
  linksFrom    TroubleshooterStepLink[] @relation("TsFrom")
  linksTo      TroubleshooterStepLink[] @relation("TsTo")
  createdAt    DateTime                @default(now())

  @@index([categoryId])
}

model TroubleshooterStepLink {
  id       Int                @id @default(autoincrement())
  from     TroubleshooterStep @relation("TsFrom", fields: [fromId], references: [id], onDelete: Cascade)
  fromId   Int
  to       TroubleshooterStep @relation("TsTo", fields: [toId], references: [id], onDelete: Cascade)
  toId     Int
  label    String             @default("")

  @@unique([fromId, toId])
}

// ───────────────────────────── reports ─────────────────────────────

enum ReportKind {
  TABULAR
  SUMMARY
  MATRIX
}

model Report {
  id         Int              @id @default(autoincrement())
  title      String
  kind       ReportKind       @default(SUMMARY)
  // declarative definition: { source, filters, groupBy, aggregates, orderBy, limit }
  definition Json             @default("{}")
  schedules  ReportSchedule[]
  runs       ReportRun[]
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
}

model ReportSchedule {
  id          Int       @id @default(autoincrement())
  report      Report    @relation(fields: [reportId], references: [id], onDelete: Cascade)
  reportId    Int
  cron        String
  recipients  Json      @default("[]")
  isEnabled   Boolean   @default(true)
  format      String    @default("json")
  lastRunAt   DateTime?
  nextRunAt   DateTime?

  @@index([reportId])
  // Load: the schedule scanner polls due+enabled schedules every 5 min.
  @@index([isEnabled, nextRunAt])
}

model ReportRun {
  id          Int      @id @default(autoincrement())
  report      Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  reportId    Int
  triggeredBy String   @default("manual")   // "manual" | "schedule"
  staffId     Int?
  rowCount    Int      @default(0)
  durationMs  Int      @default(0)
  error       String?
  resultKey   String?  // storage key for large results (future)
  createdAt   DateTime @default(now())

  @@index([reportId])
}

// ───────────────────────────── agent productivity (P3) ─────────────────────────────

/** Time logged by a staff member against a ticket (minutes). */
model TimeEntry {
  id        Int      @id @default(autoincrement())
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  ticketId  Int
  // Restrict: staff are soft-disabled (never hard-deleted), so attribution is preserved.
  staff     Staff    @relation(fields: [staffId], references: [id], onDelete: Restrict)
  staffId   Int
  minutes   Int
  note      String?
  spentAt   DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([ticketId])
  @@index([staffId])
}

/** A scheduled follow-up reminder on a ticket. */
model FollowUp {
  id          Int       @id @default(autoincrement())
  ticket      Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  ticketId    Int
  staff       Staff     @relation(fields: [staffId], references: [id], onDelete: Restrict)
  staffId     Int
  dueAt       DateTime
  note        String?
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([ticketId])
  @@index([dueAt])
  @@index([staffId])
}

/** A named, reusable set of ticket-list filters saved by a staff member. */
model SavedView {
  id        Int      @id @default(autoincrement())
  staff     Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  staffId   Int
  name      String
  filters   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([staffId, name])
  @@index([staffId])
}
