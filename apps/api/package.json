    "@testcontainers/postgresql": "^12.0.0",
    "@types/express": "^5.0.0",
    "@types/mailparser": "^3.4.6",
    "@types/nodemailer": "^6.4.17",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^2.1.8",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.1.0",
    "supertest": "^7.0.0",
    "testcontainers": "^10.16.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "unplugin-swc": "^1.5.1",
    "vitest": "^2.1.8"
  }
