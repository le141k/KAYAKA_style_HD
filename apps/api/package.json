{
  "name": "@telecom-hd/api",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\" --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "seed": "tsx src/seed/seed.ts",
    "audit:ownership": "tsx src/seed/audit-user-email-ownership.ts",
    "audit:pre-migration": "tsx src/seed/audit-pre-migration.ts",
    "audit:redis-cutover": "tsx src/seed/audit-redis-cutover.ts",
    "audit:scanner": "tsx src/seed/audit-scanner-readiness.ts",
    "audit:production": "tsx src/seed/audit-production-readiness.ts",
    "audit:attachments": "tsx src/seed/audit-attachment-storage.ts"
  },
  "dependencies": {
    "@nest-lab/throttler-storage-redis": "1.2.0",
    "@nestjs/bullmq": "11.0.4",
    "@nestjs/common": "11.1.28",
    "@nestjs/core": "11.1.28",
    "@nestjs/event-emitter": "3.1.0",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/platform-express": "11.1.28",
    "@nestjs/swagger": "11.4.6",
    "@nestjs/throttler": "6.5.0",
    "@prisma/client": "^6.1.0",
    "argon2": "^0.41.1",
    "bullmq": "^5.34.5",
    "cron-parser": "^4.9.0",
    "eventemitter2": "^6.4.9",
    "helmet": "^8.2.0",
    "imapflow": "1.4.7",
    "mailparser": "3.9.14",
    "multer": "2.2.0",
    "nestjs-pino": "4.6.1",
    "nodemailer": "9.0.3",
    "pino": "10.3.1",
    "pino-http": "11.0.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.19.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "7.8.1",
    "sanitize-html": "2.17.6",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.24",
    "@nestjs/testing": "11.1.28",
    "@testcontainers/postgresql": "^12.0.0",
    "@types/express": "^5.0.0",
    "@types/mailparser": "^3.4.6",
    "@types/multer": "2.2.0",
    "@types/nodemailer": "8.0.1",
    "@types/sanitize-html": "^2.16.1",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^2.1.8",
    "supertest": "^7.0.0",
    "testcontainers": "^10.16.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "unplugin-swc": "^1.5.1",
    "vitest": "^2.1.8"
  }
}
